---
interface Props {
  title: string;
  description: string;
  imageSrc?: string;
  imageAlt?: string;
  imageFit?: 'cover' | 'contain';
  imageSize?: string;
  imageObjectPosition?: string;
  imageWideMobileObjectPosition?: string;
  imageTabletObjectPosition?: string;
  imageDesktopObjectPosition?: string;
  imageOffsetX?: string;
  imageOffsetY?: string;
  primaryCTA: { label: string; longLabel?: string; href: string; external?: boolean };
  secondaryCTA?: { label: string; longLabel?: string; href: string; external?: boolean };
  imagePosition?: 'left' | 'right';
  id?: string;
}

const {
  title,
  description,
  imageSrc,
  imageAlt,
  imageFit = 'cover',
  imageSize,
  imageObjectPosition = 'center',
  imageWideMobileObjectPosition,
  imageTabletObjectPosition,
  imageDesktopObjectPosition,
  imageOffsetX = '0%',
  imageOffsetY = '0%',
  primaryCTA,
  secondaryCTA,
  imagePosition = 'left',
  id
} = Astro.props;

const imageScale = imageSize || '1';
const wideMobileImagePosition = imageWideMobileObjectPosition || imageObjectPosition;
const tabletImagePosition = imageTabletObjectPosition || imageObjectPosition;
const desktopImagePosition = imageDesktopObjectPosition || tabletImagePosition;
const imageStyle = [
  `object-fit: ${imageFit}`,
  `--spotlight-image-position: ${imageObjectPosition}`,
  `--spotlight-image-position-wide-mobile: ${wideMobileImagePosition}`,
  `--spotlight-image-position-tablet: ${tabletImagePosition}`,
  `--spotlight-image-position-desktop: ${desktopImagePosition}`,
  `--spotlight-image-scale: ${imageScale}`,
  `--spotlight-image-offset-x: ${imageOffsetX}`,
  `--spotlight-image-offset-y: ${imageOffsetY}`,
].join('; ');
const primaryLongLabel = primaryCTA.longLabel || primaryCTA.label;
const secondaryLongLabel = secondaryCTA?.longLabel || secondaryCTA?.label;
const headingId = id ? `${id}-heading` : `${title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')}-heading`;
---

<section class="spotlight-card" id={id} aria-labelledby={headingId}>
  {imageSrc && (
    <img
      class="spotlight-card-bg"
      src={imageSrc}
      alt=""
      style={imageStyle}
      aria-hidden="true"
    />
  )}
  <div class="spotlight-card-overlay"></div>
  <div class="spotlight-card-content">
    <h2 id={headingId}>{title}</h2>
    <p class="description">{description}</p>

    <div class="spotlight-ctas">
      <a
        href={primaryCTA.href}
        class="cta primary"
        target={primaryCTA.external ? '_blank' : undefined}
        rel={primaryCTA.external ? 'noopener noreferrer' : undefined}
      >
        <span class="cta-label-short">{primaryCTA.label}</span>
        <span class="cta-label-long">{primaryLongLabel}</span>
        {primaryCTA.external && <span aria-hidden="true"> ↗</span>}
      </a>
      {secondaryCTA && (
        <a
          href={secondaryCTA.href}
          class="cta secondary"
          target={secondaryCTA.external ? '_blank' : undefined}
          rel={secondaryCTA.external ? 'noopener noreferrer' : undefined}
        >
          <span class="cta-label-short">{secondaryCTA.label}</span>
          <span class="cta-label-long">{secondaryLongLabel}</span>
          {secondaryCTA.external && <span aria-hidden="true"> ↗</span>}
        </a>
      )}
    </div>
  </div>
</section>

<style>
  /* Modern card with background image and overlay */
  .spotlight-card {
    position: relative;
    overflow: hidden;
    padding: 0;
    min-height: 320px;
    display: flex;
    align-items: flex-end;
    background: hsl(var(--card));
    transition: transform 0.3s ease;
  }

  .spotlight-card:hover {
    transform: translateY(-2px);
  }

  .spotlight-card-bg {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    object-position: var(--spotlight-image-position);
    transform:
      translate(var(--spotlight-image-offset-x), var(--spotlight-image-offset-y))
      scale(var(--spotlight-image-scale));
    transform-origin: var(--spotlight-image-position);
    opacity: 1;
    pointer-events: none;
    user-select: none;
  }

  /* Diagonal gradient overlay from bottom-left to top-right */
  .spotlight-card-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 120% 100% at bottom left,
        rgba(0, 0, 0, 0.92) 0%,
        rgba(0, 0, 0, 0.8) 25%,
        rgba(0, 0, 0, 0.6) 45%,
        rgba(0, 0, 0, 0.4) 60%,
        rgba(0, 0, 0, 0.2) 80%,
        transparent 100%
      );
    pointer-events: none;
  }

  /* Apple-style glass effect: progressive blur from bottom to top */
  .spotlight-card-content {
    position: relative;
    z-index: 1;
    padding: 2rem 1.5rem;
    width: 100%;
  }

  /* Multiple glass layers with progressive blur */
  .spotlight-card-content::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      to top,
      rgba(255, 255, 255, 0.15) 0%,
      rgba(255, 255, 255, 0.1) 30%,
      rgba(255, 255, 255, 0.05) 60%,
      transparent 100%
    );
    backdrop-filter: blur(16px) saturate(180%) brightness(1.1);
    -webkit-backdrop-filter: blur(16px) saturate(180%) brightness(1.1);
    mask-image: linear-gradient(to top, black 0%, black 40%, transparent 100%);
    -webkit-mask-image: linear-gradient(to top, black 0%, black 40%, transparent 100%);
    pointer-events: none;
  }

  .spotlight-card-content::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      to top,
      rgba(255, 255, 255, 0.08) 0%,
      rgba(255, 255, 255, 0.04) 50%,
      transparent 100%
    );
    backdrop-filter: blur(8px) saturate(150%) brightness(1.05);
    -webkit-backdrop-filter: blur(8px) saturate(150%) brightness(1.05);
    mask-image: linear-gradient(to top, transparent 0%, black 35%, black 70%, transparent 100%);
    -webkit-mask-image: linear-gradient(to top, transparent 0%, black 35%, black 70%, transparent 100%);
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    pointer-events: none;
  }

  /* Ensure text content is above glass layers */
  .spotlight-card-content > * {
    position: relative;
    z-index: 1;
  }

  .spotlight-card h2 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.55rem;
    border-bottom: 0;
    background: linear-gradient(to right, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.22) 38%, transparent 78%) left bottom / 100% 1px no-repeat;
    text-wrap: pretty;
    color: hsl(var(--foreground));
    text-shadow:
      0 1px 3px rgba(0, 0, 0, 0.8),
      0 2px 8px rgba(0, 0, 0, 0.6);
    font-weight: 700;
  }

  .description {
    font-size: 0.9rem;
    line-height: 1.5;
    color: hsl(0 0% 94%);
    margin-bottom: 1.25rem;
    text-wrap: pretty;
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 0.8),
      0 2px 6px rgba(0, 0, 0, 0.5);
    font-weight: 500;
  }

  .spotlight-ctas {
    container-type: inline-size;
    display: flex;
    flex-direction: row;
    gap: 0.625rem;
  }

  .cta {
    display: inline-block;
    flex: 1 1 0;
    min-width: 0;
    padding: 0.625rem 0.875rem;
    text-align: center;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.875rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: all 0.2s ease;
  }

  .cta-label-long {
    display: none;
  }

  @container (min-width: 21rem) {
    .cta-label-short {
      display: none;
    }

    .cta-label-long {
      display: inline;
    }
  }

  .cta.primary {
    background: rgba(255, 255, 255, 0.15);
    color: hsl(var(--foreground));
    border-color: rgba(255, 255, 255, 0.4);
  }

  .cta.secondary {
    background: rgba(0, 0, 0, 0.3);
    color: hsl(0 0% 88%);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .cta:hover {
    background: rgba(255, 255, 255, 0.25);
    border-color: rgba(255, 255, 255, 0.6);
    color: hsl(var(--foreground));
    transform: translateY(-1px);
  }

  /* Tablet: slightly taller cards */
  @media (min-width: 600px) {
    .spotlight-card-bg {
      object-position: var(--spotlight-image-position-wide-mobile);
      transform-origin: var(--spotlight-image-position-wide-mobile);
    }
  }

  @media (min-width: 768px) {
    .spotlight-card-bg {
      object-position: var(--spotlight-image-position-tablet);
      transform-origin: var(--spotlight-image-position-tablet);
    }

    .spotlight-card {
      min-height: 380px;
    }

    .spotlight-card-content {
      padding: 2.5rem 2rem;
    }

    .spotlight-card h2 {
      font-size: 1.75rem;
    }

    .description {
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .spotlight-ctas {
      gap: 0.75rem;
    }
  }

  /* Wide spotlight layout: large tablets and desktop */
  @media (min-width: 900px) {
    .spotlight-card-bg {
      object-position: var(--spotlight-image-position-desktop);
      transform-origin: var(--spotlight-image-position-desktop);
    }

    .spotlight-card {
      min-height: 440px;
    }

    .spotlight-card-overlay {
      background:
        radial-gradient(
          ellipse 110% 90% at bottom left,
          rgba(0, 0, 0, 0.94) 0%,
          rgba(0, 0, 0, 0.82) 25%,
          rgba(0, 0, 0, 0.65) 45%,
          rgba(0, 0, 0, 0.45) 60%,
          rgba(0, 0, 0, 0.25) 75%,
          transparent 100%
        );
    }

    .spotlight-card-content {
      padding: 3rem 2.5rem 1.5rem 2.5rem;
    }

    .spotlight-card-content::before {
      backdrop-filter: blur(16px) saturate(200%) brightness(1.12);
      -webkit-backdrop-filter: blur(16px) saturate(200%) brightness(1.12);
    }

    .spotlight-card-content::after {
      backdrop-filter: blur(8px) saturate(160%) brightness(1.08);
      -webkit-backdrop-filter: blur(8px) saturate(160%) brightness(1.08);
      border-top: 1px solid rgba(255, 255, 255, 0.25);
    }

    .spotlight-card h2 {
      font-size: 1.5rem;
    }

    .description {
      font-size: 0.875rem;
    }

    .cta {
      font-size: 0.8125rem;
      padding: 0.5rem 1rem;
    }
  }
</style>
