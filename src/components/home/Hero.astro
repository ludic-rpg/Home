---
import { getCollection } from 'astro:content';
import Avatar from '../Avatar.astro';
import { blogSlug, blogUrl } from '../../lib/blog/posts';

const featuredPostSlug = 'building-the-alien-rpg-motion-tracker-immersion-without-friction';
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const featuredPost = allPosts.find((post) => blogSlug(post) === featuredPostSlug);

const badgeText = 'Featured Post';
const avatarHoverVideo = '/assets/video/avatar/avatar-dog-happy-owner.mp4';
const avatarVideos = [
  '/assets/video/avatar/avatar-dog-angry.mp4',
  '/assets/video/avatar/avatar-dog-curious-ear.mp4',
  '/assets/video/avatar/avatar-wind-hair.mp4',
  '/assets/video/avatar/avatar-dog-look-right-a.mp4',
  '/assets/video/avatar/avatar-dog-look-right-b.mp4',
];
---

<script>
  import '../../scripts/hero-animations';
</script>

<section class="hero" aria-labelledby="home-hero-title">
  <div class="hero-purpose">
    <h1 class="hero-title" id="home-hero-title">Immersive&nbsp;<span class="hero-tt">TT</span>RPG Experiences</h1>
    <p class="hero-baseline">
      Creative experiments mixing narrative, visuals, props, and technology to design rich tabletop RPG experiences.
      A space for imagination, fun, and design to meet.
    </p>
  </div>

  <div class="hero-content-row">
    {featuredPost && (
      <article aria-labelledby="featured-post-title">
        <a href={blogUrl(featuredPost)} class="hero-latest" data-fathom-event="Click Featured Post | Home">
          <p class="latest-badge">{badgeText}</p>
          <h2 id="featured-post-title">{featuredPost.data.title}</h2>
          <span class="read-more">Read more →</span>
        </a>
      </article>
    )}

    <a href="/about" class="hero-avatar" aria-label="About Ludo" data-fathom-event="Click Avatar | Home">
      <Avatar
        chance={0.2}
        alt=""
        hoverVideoSrc={avatarHoverVideo}
        loading="eager"
        videoSrcs={avatarVideos}
      />
    </a>
  </div>
</section>

<style>
  /* ===== MOBILE (Default) ===== */
  .hero {
    padding: 0;
    /* Avatar and notch alignment position */
    --avatar-position: 80%;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Mobile: Stack bubble and avatar with spacing */
  .hero-content-row {
    display: flex;
    flex-direction: column;
    gap: 0;
    isolation: isolate;
    position: relative;
    width: 100%;
  }

  .hero-latest {
    width: 100%;
  }

  .hero-avatar {
    align-self: center;
    margin-left: 0;
    margin-top: -1rem;
    position: relative;
    z-index: 1;
  }

  .hero-avatar :global(.avatar-media) {
    --avatar-size: 100px;
    --avatar-border: none;
    transition: transform 0.3s ease;
  }

  .hero-avatar:hover :global(.avatar-media),
  .hero-avatar:focus-visible :global(.avatar-media) {
    transform: scale(1.05);
  }

  .hero-purpose {
    grid-area: purpose;
    text-align: center;
    width: 100%;
    max-width: 100%;
    justify-self: center;
    position: relative;
    min-width: 0;
    overflow: hidden;
  }

  /* Subtle glow behind punchline */
  .hero-purpose::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    background: radial-gradient(
      ellipse at center,
      rgba(255, 255, 255, 0.12) 0%,
      rgba(255, 255, 255, 0.06) 40%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 0;
  }

  .hero-title {
    font-family: 'Rajdhani', sans-serif;
    /* Dynamic font size based on viewport width */
    font-size: clamp(2rem, 7vw, 5rem);
    font-weight: 700;
    line-height: 1.1;
    /* Dynamic letter spacing based on viewport width */
    letter-spacing: clamp(0em, 0.6vw, 0.1em);
    margin: 0 0 1.5rem 0;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
    text-wrap: pretty;

    /* Outline text - schematic aesthetic */
    color: transparent !important;
    background: transparent !important;
    -webkit-text-fill-color: transparent !important;
    /* Dynamic stroke width */
    -webkit-text-stroke-width: clamp(0.75px, 0.2vw, 1.25px);
    -webkit-text-stroke-color: hsl(var(--foreground));
    text-stroke: clamp(0.75px, 0.2vw, 1.25px) hsl(var(--foreground));
  }

  /* Subdued "TT" styling with diagonal gradient */
  .hero-tt {
    font-weight: 700;
    background: linear-gradient(
      135deg,
      hsl(0 0% 15%) 0%,
      hsl(0 0% 25%) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    -webkit-text-stroke-width: 0;
    text-stroke: 0;
  }

  .hero-baseline {
    font-size: 1;
    font-weight: 400;
    line-height: 1.7;
    color: hsl(var(--foreground));
    margin: 0;
    letter-spacing: 0.015em;
    opacity: 0.9;
    text-align: center;
    text-wrap: pretty;

    margin-left: auto;
    margin-right: auto;
    position: relative;
    z-index: 1;
  }

  .hero-latest {
    grid-area: latest;
    padding: 1.5rem 1.5rem 1rem 1.5rem;
    color: hsl(var(--background));
    position: relative;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    min-width: 0;
    margin-bottom: 25px;
    z-index: 2;
    text-decoration: none;
    display: block;
    cursor: pointer;
    transition: transform 0.2s ease-out;
    isolation: isolate;
  }

  /* On hover, lift up and scale slightly */
  .hero-latest:hover {
    transform: translateY(-4px) scale(1.02);
  }

  /* Background with gradient - darker top-left corner */
  .hero-latest::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      hsl(0 0% 50%) 0%,
      hsl(0 0% 96%) 70%
    );
    z-index: 1;
    pointer-events: none;
  }

  /* On hover, switch to solid off-white instantly (no transition to avoid blink) */
  .hero-latest:hover::before {
    background: hsl(0 0% 96%);
  }

  /* Mobile: Centered triangle notch with tilt and offset */
  .hero-latest::after {
    content: '';
    position: absolute;
    bottom: -28px;
    left: calc(50% + 40px);
    transform: translateX(-50%) skewX(-22deg);
    width: 0;
    height: 0;
    border-top: 50px solid hsl(0 0% 96%);
    border-left: 8px solid transparent;
    border-right: 40px solid transparent;
    filter: drop-shadow(2px 3px 4px rgba(0, 0, 0, 0.3));
    z-index: 0;
    pointer-events: none;
  }



  .latest-badge {
    position: absolute;
    top: -0.75rem;
    left: 1rem;
    background: hsl(var(--background));
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: hsl(var(--muted-foreground));
    border: 1px solid hsl(var(--border));
    z-index: 5;
  }

  .hero-latest h2 {
    font-family: 'Bangers', cursive;
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    border: none;
    padding: 0;
    font-weight: 400;
    letter-spacing: 0.02em;
    text-align: right;
    position: relative;
    z-index: 4;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.9);
  }


  .read-more {
    display: block;
    color: hsl(var(--background));
    opacity: 0.6;
    font-weight: 400;
    font-size: 0.75rem;
    text-align: right;
    position: relative;
    z-index: 4;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.9);
  }

  /* ===== TABLET & DESKTOP (Side-by-side layout) ===== */
  @media (min-width: 768px) {
    .hero {
      padding: 0;
    }

    .hero {
      align-items: center;
      gap: 5rem;
    }

    .hero-purpose {
      width: 100%;
      text-align: center;
    }

    /* Wrapper for bubble + avatar - centered as a single block */
    .hero-content-row {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 1rem;
      width: auto;
    }

    .hero-latest {
      width: auto;
      max-width: 600px;
      margin-bottom: 0;
    }

    .hero-avatar {
      margin-top: 0;
      margin-left: 0;
      display: flex;
      align-items: center;
      position: relative;
    }

    .hero-avatar :global(.avatar-media) {
      --avatar-size: 120px;
    }

    .hero-purpose {
      text-align: center;
      justify-self: center;
      grid-column: 1 / -1;
    }

    /* Tablet/Desktop: right-pointing symmetrical notch */
    .hero-latest::after {
      right: -28px;
      top: 50%;
      bottom: auto;
      left: auto;
      transform: translateY(-50%);
      border-left: 50px solid hsl(0 0% 96%);
      border-top: 25px solid transparent;
      border-bottom: 25px solid transparent;
      border-right: none;
      filter: drop-shadow(3px 2px 4px rgba(0, 0, 0, 0.3));
    }
  }

  /* ===== LARGE DESKTOP (Bigger text) ===== */
  @media (min-width: 1024px) {
    .hero-title {
      font-size: 3rem;
      -webkit-text-stroke-width: 1.25px;
      text-stroke: 1.25px;
    }

    .hero-baseline {
      font-size: 1rem;
      letter-spacing: 0.02em;
    }
  }

  /* ===== SCROLL ANIMATIONS ===== */

  /* Initial state: invisible but space reserved (no layout shift) */
  .hero-avatar,
  .hero-latest {
    opacity: 0;
  }

  /* Avatar: Circular iris/mask reveal animation */
  .hero-avatar {
    clip-path: circle(0% at center);
    transition: clip-path 0.3s ease-out, opacity 0.3s ease-out;
  }

  .hero-avatar.animate-in {
    clip-path: circle(50% at center);
    opacity: 1;
  }

  /* Bubble: Pop with shake effect */
  @keyframes popShake {
    0% {
      transform: scale(0.8) rotate(0deg);
      opacity: 0;
    }
    60% {
      transform: scale(1.05) rotate(2deg);
      opacity: 1;
    }
    80% {
      transform: scale(0.98) rotate(-1deg);
    }
    100% {
      transform: scale(1) rotate(0deg);
      opacity: 1;
    }
  }

  .hero-latest {
    transform-origin: center;
  }

  .hero-latest.animate-in {
    animation: popShake 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55) 0.4s forwards;
  }

  /* Reduced motion: show immediately without animation */
  @media (prefers-reduced-motion: reduce) {
    .hero-avatar.no-motion,
    .hero-latest.no-motion {
      opacity: 1;
      clip-path: none;
      animation: none;
      transform: none;
    }
  }

  /* Desktop: adjust bubble pop animation to account for hover transform */
  @media (min-width: 768px) {
    @keyframes popShake {
      0% {
        transform: scale(0.8) rotate(0deg);
        opacity: 0;
      }
      60% {
        transform: scale(1.05) rotate(2deg);
        opacity: 1;
      }
      80% {
        transform: scale(0.98) rotate(-1deg);
      }
      100% {
        transform: scale(1) rotate(0deg);
        opacity: 1;
      }
    }
  }
</style>
