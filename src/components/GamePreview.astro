---
interface Props {
  gameName: string;
  summary?: string;
  glowColor: 'green' | 'blue';
  publisher?: string;
  id?: string;
}

const { gameName, summary, glowColor, publisher, id } = Astro.props;
const glowClass = `glow-${glowColor}`;
---

<section class={`game-preview wireframe-border ${glowClass}`} id={id} aria-labelledby={id ? `${id}-heading` : undefined}>
  <div class="game-header">
    <div class="game-header-title">
      <h2 class="game-title" id={id ? `${id}-heading` : undefined}>
        <span class="game-title-muted">A Ludic take on</span>
        <span>{gameName}</span>
      </h2>
    </div>
    <div class="game-summary">
      {summary && <p>{summary}</p>}
      <slot name="summary" />
    </div>
  </div>

  <ul class="projects-grid">
    <slot />
  </ul>
</section>

<style>
  /* ===== MOBILE (Default) ===== */
  .game-preview {
    position: relative;
    border: none;
    padding: 2rem 1.5rem;
    background: rgba(0, 0, 0, 0.4);
  }

  :global(.game-preview:not(.game-preview ~ .game-preview)) {
    background:
      linear-gradient(135deg, transparent 0%, rgba(0, 0, 0, 0.16) 34%, rgba(0, 0, 0, 0.44) 100%);
  }

  :global(.game-preview:not(:has(~ .game-preview))) {
    background:
      linear-gradient(135deg, rgba(0, 0, 0, 0.44) 0%, rgba(0, 0, 0, 0.16) 66%, transparent 100%);
  }

  :global(.game-preview:not(.game-preview ~ .game-preview):not(:has(~ .game-preview))) {
    background: rgba(0, 0, 0, 0.4);
  }

  .game-preview::before,
  .game-preview::after {
    content: '';
    position: absolute;
    width: min(12rem, 48%);
    height: min(12rem, 48%);
    pointer-events: none;
    opacity: 0.9;
  }

  .game-preview::before {
    top: 0;
    right: 0;
    background:
      linear-gradient(to left, hsl(var(--foreground) / 0.42), hsl(var(--border) / 0.12) 78%, transparent) top right / 100% 1px no-repeat,
      linear-gradient(to bottom, hsl(var(--foreground) / 0.42), hsl(var(--border) / 0.12) 78%, transparent) top right / 1px 100% no-repeat;
  }

  .game-preview::after {
    bottom: 0;
    left: 0;
    background:
      linear-gradient(to right, hsl(var(--foreground) / 0.42), hsl(var(--border) / 0.12) 78%, transparent) bottom left / 100% 1px no-repeat,
      linear-gradient(to top, hsl(var(--foreground) / 0.42), hsl(var(--border) / 0.12) 78%, transparent) bottom left / 1px 100% no-repeat;
  }

  .game-header {
    margin-bottom: 2rem;
  }

  .game-header-title {
    display: grid;
    margin-bottom: 1rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid hsl(var(--border));
  }

  .game-title {
    margin: 0;
    text-align: right;
    text-wrap: pretty;
    border-bottom: none;
    padding-bottom: 0;
    font-family: 'Rajdhani', 'Inter', sans-serif;
    color: hsl(var(--foreground));
    font-size: clamp(1.75rem, 7vw, 3.25rem);
    font-weight: 900;
    letter-spacing: 0.015em;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .game-title-muted {
    color: hsl(var(--muted-foreground));
    opacity: 0.14;
  }

  .game-summary {
    font-size: 0.95rem;
    line-height: 1.6;
    color: hsl(var(--body-text));
  }

  .game-summary p {
    margin: 0;
    text-wrap: pretty;
  }

  .game-summary a {
    color: inherit;
    text-decoration-line: underline;
    text-decoration-color: hsl(var(--link-underline));
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
    transition:
      color 0.18s ease,
      background-color 0.18s ease,
      text-decoration-color 0.18s ease;
  }

  .game-summary a:visited {
    color: inherit;
  }

  .game-summary a:hover,
  .game-summary a:focus-visible {
    color: hsl(var(--foreground));
    background-color: hsl(var(--link-highlight));
    text-decoration-color: hsl(var(--link-underline-hover));
  }

  .projects-grid {
    --project-card-min: 16.5rem; /* 264px: smallest comfortable card width */
    --project-card-max: 23.75rem; /* 380px: comfortable one-column phone cap */

    display: grid;
    grid-template-columns: repeat(
      auto-fit,
      minmax(min(100%, var(--project-card-min)), 1fr)
    );
    gap: 1rem;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .projects-grid :global(.project-card-item) {
    min-width: 0;
    margin-top: 0;
  }

  .projects-grid :global(.project-card) {
    width: 100%;
    max-width: var(--project-card-max);
    justify-self: center;
  }

  /* ===== DESKTOP ===== */
  @media (min-width: 1024px) {
    .game-preview {
      padding: 3rem;
    }

    .projects-grid {
      gap: 2rem;
    }
  }
</style>
