---
import { getCollection } from 'astro:content';

// Fetch latest blog post
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPost = allPosts.sort((a, b) =>
  new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf()
)[0];

const formattedDate = latestPost ? new Date(latestPost.data.publishDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}) : '';

const badgeDate = latestPost ? new Date(latestPost.data.publishDate).toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric'
}) : '';
---

<section class="hero">
  <div class="hero-grid">

    <div class="hero-purpose">
      <h1 class="hero-title">Immersive&nbsp;<span class="hero-tt">TT</span>RPG<br>Experiences</h1>
      <p class="hero-baseline">
        Stories, props, visuals, sound, and tools for Game Masters
        that turn atmosphere into moments players can feel and play with.
      </p>
    </div>

    {latestPost && (
      <div class="hero-latest">
        <span class="latest-badge">{badgeDate}</span>
        <h3>
          <a href={`/blog/${latestPost.slug}`}>{latestPost.data.title}</a>
        </h3>
        <a href={`/blog/${latestPost.slug}`} class="read-more">Read more →</a>
      </div>
    )}

    <a href="/about" class="hero-avatar" aria-label="About Ludo">
      <img
        src="/assets/img/ludo.png"
        alt="Ludo's avatar"
        width="180"
        height="180"
      />
    </a>

  </div>
</section>

<style>
  /* ===== MOBILE (Default) ===== */
  .hero {
    padding: 1rem 0;
    /* Avatar and notch alignment position */
    --avatar-position: 80%;
  }

  .hero-grid {
    display: grid;
    grid-template-areas:
      "purpose"
      "latest"
      "avatar";
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .hero-avatar {
    grid-area: avatar;
    justify-self: start;
    margin-left: calc(var(--avatar-position) - 50px);
    margin-top: -40px;
  }

  .hero-avatar img {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    border: 2px solid hsl(var(--border));
    transition: transform 0.3s ease;
    display: block;
  }

  .hero-avatar:hover img,
  .hero-avatar:focus-visible img {
    transform: scale(1.05);
  }

  .hero-purpose {
    grid-area: purpose;
    text-align: center;
    width: 100%;
    max-width: 100%;
    justify-self: center;
    position: relative;
    min-width: 0;
  }

  /* Subtle glow behind punchline */
  .hero-purpose::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 130%;
    height: 130%;
    background: radial-gradient(
      ellipse at center,
      rgba(255, 255, 255, 0.06) 0%,
      rgba(255, 255, 255, 0.03) 40%,
      transparent 70%
    );
    pointer-events: none;
    z-index: -1;
  }

  .hero-title {
    font-family: 'Rajdhani', sans-serif;
    /* Dynamic font size based on viewport width */
    font-size: clamp(2rem, 7vw, 5rem);
    font-weight: 900;
    line-height: 1.1;
    /* Dynamic letter spacing based on viewport width */
    letter-spacing: clamp(0em, 0.6vw, 0.1em);
    margin: 0 0 1.5rem 0;
    text-transform: uppercase;

    /* Outline text - schematic aesthetic */
    color: transparent !important;
    background: transparent !important;
    -webkit-text-fill-color: transparent !important;
    /* Dynamic stroke width */
    -webkit-text-stroke-width: clamp(0.75px, 0.2vw, 1.25px);
    -webkit-text-stroke-color: hsl(var(--foreground));
    text-stroke: clamp(0.75px, 0.2vw, 1.25px) hsl(var(--foreground));
  }

  /* Subdued "TT" styling with diagonal gradient */
  .hero-tt {
    font-weight: 900;
    background: linear-gradient(
      135deg,
      hsl(0 0% 15%) 0%,
      hsl(0 0% 25%) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    -webkit-text-stroke-width: 0;
    text-stroke: 0;
  }

  .hero-baseline {
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.7;
    color: hsl(var(--foreground));
    margin: 0;
    letter-spacing: 0.015em;
    opacity: 0.9;
    text-align: center;
    max-width: 50ch;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-latest {
    grid-area: latest;
    padding: 1.5rem;
    background: hsl(var(--foreground));
    color: hsl(var(--background));
    position: relative;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    min-width: 0;
    margin-bottom: 25px;
  }

  /* Asymmetrical triangle notch pointing bottom-right */
  .hero-latest::after {
    content: '';
    position: absolute;
    bottom: -28px;
    left: calc(var(--avatar-position) + 12px);
    width: 0;
    height: 0;
    border-top: 50px solid hsl(var(--foreground));
    border-left: 8px solid transparent;
    border-right: 40px solid transparent;
    transform: skewX(-22deg);
  }

  .hero-latest:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
  }


  .latest-badge {
    position: absolute;
    top: -0.75rem;
    left: 1rem;
    background: hsl(var(--background));
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: hsl(var(--muted-foreground));
    border: 1px solid hsl(var(--border));
  }

  .hero-latest h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    border: none;
    padding: 0;
  }

  .hero-latest h3 a {
    color: hsl(var(--background));
    text-decoration: none;
  }

  .hero-latest h3 a:hover {
    text-decoration: underline;
    opacity: 0.8;
  }

  .hero-latest time {
    display: block;
    font-size: 0.875rem;
    color: hsl(var(--background));
    opacity: 0.7;
    margin-bottom: 1rem;
  }

  .read-more {
    display: block;
    color: hsl(var(--background));
    opacity: 0.6;
    text-decoration: none;
    font-weight: 400;
    font-size: 0.8125rem;
    text-align: right;
  }

  .read-more:hover {
    opacity: 0.8;
  }

  /* ===== DESKTOP (Enriched) ===== */
  @media (min-width: 1024px) {
    .hero {
      padding: 2.5rem 0;
    }

    .hero-grid {
      grid-template-areas:
        "purpose purpose"
        "latest avatar";
      grid-template-columns: 1fr auto;
      gap: 2rem 3rem;
      align-items: start;
      justify-items: start;
    }

    .hero-avatar {
      justify-self: end;
      align-self: start;
    }

    .hero-avatar img {
      width: 180px;
      height: 180px;
    }

    .hero-purpose {
      text-align: center;
      justify-self: center;
      grid-column: 1 / -1;
    }

    .hero-title {
      font-size: 5rem;
      -webkit-text-stroke-width: 1.25px;
      text-stroke: 1.25px;
    }

    .hero-baseline {
      font-size: 1.25rem;
      letter-spacing: 0.02em;
    }

    .hero-latest {
      width: auto;
    }

    /* Hide speech bubble on desktop */
    .hero-latest::after {
      display: none;
    }
  }
</style>
