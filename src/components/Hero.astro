---
import { getCollection } from 'astro:content';

// Fetch latest blog post
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPost = allPosts.sort((a, b) =>
  new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf()
)[0];

const badgeDate = latestPost ? new Date(latestPost.data.publishDate).toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric'
}) : '';
---

<section class="hero">
  <div class="hero-grid">

    <div class="hero-purpose">
      <h1 class="hero-title">Immersive&nbsp;<span class="hero-tt">TT</span>RPG<br>Experiences</h1>
      <p class="hero-baseline">
        Stories, props, visuals, sound, and tools for Game Masters
        that turn atmosphere into moments players can feel and play with.
      </p>
    </div>

    {latestPost && (
      <a href={`/blog/${latestPost.slug}`} class="hero-latest">
        <span class="latest-badge">{badgeDate}</span>
        <h3>{latestPost.data.title}</h3>
        <span class="read-more">Read more →</span>
      </a>
    )}

    <a href="/about" class="hero-avatar" aria-label="About Ludo">
      <img
        src="/assets/img/ludo.png"
        alt="Ludo's avatar"
        width="180"
        height="180"
      />
    </a>

  </div>
</section>

<style>
  /* ===== MOBILE (Default) ===== */
  .hero {
    padding: 1rem 0;
    /* Avatar and notch alignment position */
    --avatar-position: 80%;
  }

  .hero-grid {
    display: grid;
    grid-template-areas:
      "purpose"
      "latest"
      "avatar";
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .hero-avatar {
    grid-area: avatar;
    justify-self: start;
    margin-left: calc(var(--avatar-position) - 50px);
    margin-top: calc(-3rem - 16px);
    position: relative;
    z-index: 1;
  }

  .hero-avatar img {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    border: 2px solid hsl(var(--border));
    transition: transform 0.3s ease;
    display: block;
  }

  .hero-avatar:hover img,
  .hero-avatar:focus-visible img {
    transform: scale(1.05);
  }

  .hero-purpose {
    grid-area: purpose;
    text-align: center;
    width: 100%;
    max-width: 100%;
    justify-self: center;
    position: relative;
    min-width: 0;
  }

  /* Subtle glow behind punchline */
  .hero-purpose::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 130%;
    height: 130%;
    background: radial-gradient(
      ellipse at center,
      rgba(255, 255, 255, 0.06) 0%,
      rgba(255, 255, 255, 0.03) 40%,
      transparent 70%
    );
    pointer-events: none;
    z-index: -1;
  }

  .hero-title {
    font-family: 'Rajdhani', sans-serif;
    /* Dynamic font size based on viewport width */
    font-size: clamp(2rem, 7vw, 5rem);
    font-weight: 900;
    line-height: 1.1;
    /* Dynamic letter spacing based on viewport width */
    letter-spacing: clamp(0em, 0.6vw, 0.1em);
    margin: 0 0 1.5rem 0;
    text-transform: uppercase;

    /* Outline text - schematic aesthetic */
    color: transparent !important;
    background: transparent !important;
    -webkit-text-fill-color: transparent !important;
    /* Dynamic stroke width */
    -webkit-text-stroke-width: clamp(0.75px, 0.2vw, 1.25px);
    -webkit-text-stroke-color: hsl(var(--foreground));
    text-stroke: clamp(0.75px, 0.2vw, 1.25px) hsl(var(--foreground));
  }

  /* Subdued "TT" styling with diagonal gradient */
  .hero-tt {
    font-weight: 900;
    background: linear-gradient(
      135deg,
      hsl(0 0% 15%) 0%,
      hsl(0 0% 25%) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    -webkit-text-stroke-width: 0;
    text-stroke: 0;
  }

  .hero-baseline {
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.7;
    color: hsl(var(--foreground));
    margin: 0;
    letter-spacing: 0.015em;
    opacity: 0.9;
    text-align: center;
    max-width: 50ch;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-latest {
    grid-area: latest;
    padding: 1.5rem 1.5rem 1rem 1.5rem;
    color: hsl(var(--background));
    position: relative;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    min-width: 0;
    margin-bottom: 25px;
    z-index: 2;
    text-decoration: none;
    display: block;
    cursor: pointer;
    transition: transform 0.2s ease-out;
  }

  /* On hover, lift up and scale slightly */
  .hero-latest:hover {
    transform: translateY(-4px) scale(1.02);
  }

  /* Background gradient layer that stays white on hover */
  .hero-latest::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      hsl(var(--background) / 0.4) 0%,
      hsl(0 0% 96%) 70%
    );
    z-index: -1;
  }

  /* On hover, switch to solid off-white instantly (no transition to avoid blink) */
  .hero-latest:hover::before {
    background: hsl(0 0% 96%);
  }

  /* Asymmetrical triangle notch pointing bottom-right */
  .hero-latest::after {
    content: '';
    position: absolute;
    bottom: -28px;
    left: calc(var(--avatar-position) + 12px);
    width: 0;
    height: 0;
    border-top: 50px solid hsl(0 0% 96%);
    border-left: 8px solid transparent;
    border-right: 40px solid transparent;
    transform: skewX(-22deg);
    filter: drop-shadow(2px 3px 4px rgba(0, 0, 0, 0.3));
    z-index: -2;
  }



  .latest-badge {
    position: absolute;
    top: -0.75rem;
    left: 1rem;
    background: hsl(var(--background));
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: hsl(var(--muted-foreground));
    border: 1px solid hsl(var(--border));
    z-index: 5;
  }

  .hero-latest h3 {
    font-family: 'Bangers', cursive;
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    border: none;
    padding: 0;
    font-weight: 400;
    letter-spacing: 0.02em;
    text-align: right;
    position: relative;
    z-index: 4;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.9);
  }


  .read-more {
    display: block;
    color: hsl(var(--background));
    opacity: 0.6;
    font-weight: 400;
    font-size: 0.75rem;
    text-align: right;
    position: relative;
    z-index: 4;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.9);
  }

  /* ===== TABLET & DESKTOP (Side-by-side layout) ===== */
  @media (min-width: 768px) {
    .hero {
      padding: 2.5rem 0;
    }

    .hero-grid {
      grid-template-areas:
        "purpose purpose"
        "latest avatar";
      grid-template-columns: 1fr auto;
      gap: 3rem 0;
      align-items: center;
      justify-items: start;
    }

    .hero-avatar {
      justify-self: start;
      align-self: center;
      margin-top: 0;
      margin-left: 0;
      display: flex;
      align-items: center;
    }

    .hero-avatar img {
      width: 120px;
      height: 120px;
    }

    .hero-purpose {
      text-align: center;
      justify-self: center;
      grid-column: 1 / -1;
    }

    .hero-latest {
      width: auto;
      margin-bottom: 0;
    }

    /* Tablet/Desktop: right-pointing symmetrical notch */
    .hero-latest::after {
      right: -28px;
      top: 50%;
      bottom: auto;
      left: auto;
      transform: translateY(-50%);
      border-left: 50px solid hsl(0 0% 96%);
      border-top: 25px solid transparent;
      border-bottom: 25px solid transparent;
      border-right: none;
      filter: drop-shadow(3px 2px 4px rgba(0, 0, 0, 0.3));
    }
  }

  /* ===== LARGE DESKTOP (Bigger text and avatar) ===== */
  @media (min-width: 1024px) {
    .hero-title {
      font-size: 5rem;
      -webkit-text-stroke-width: 1.25px;
      text-stroke: 1.25px;
    }

    .hero-baseline {
      font-size: 1.25rem;
      letter-spacing: 0.02em;
    }

    .hero-avatar img {
      width: 180px;
      height: 180px;
    }
  }
</style>
