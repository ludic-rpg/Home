---
interface Props {
  alt?: string;
  chance?: number;
  class?: string;
  loading?: 'eager' | 'lazy';
  hoverVideoSrc?: string;
  posterSrc?: string;
  videoSrc?: string;
  videoSrcs?: string[];
}

const {
  alt = "Ludo's avatar",
  chance = 0.75,
  class: className = '',
  hoverVideoSrc = '',
  loading = 'lazy',
  posterSrc = '/assets/img/ludo-video-first-frame.png',
  videoSrc = '/assets/video/avatar/avatar-human-small-wind-optimized.mp4',
  videoSrcs = [videoSrc],
} = Astro.props;

const videoSources = videoSrcs.filter(Boolean).join(' ');
---

<span
  class:list={['avatar-media', className]}
  data-avatar-media
  data-avatar-chance={chance}
  data-avatar-video-srcs={videoSources}
  data-avatar-hover-src={hoverVideoSrc}
>
  <img
    class="avatar-media__poster"
    src={posterSrc}
    alt={alt}
    width="180"
    height="180"
    loading={loading}
  />
  <video
    class="avatar-media__video"
    data-avatar-random-video
    muted
    playsinline
    preload="none"
    poster={posterSrc}
    aria-hidden="true"
  ></video>
  <video
    class="avatar-media__video"
    data-avatar-hover-video
    muted
    playsinline
    preload="none"
    poster={posterSrc}
    aria-hidden="true"
  ></video>
</span>

<script>
  import '../scripts/avatar-media';
</script>

<style>
  .avatar-media {
    display: block;
    position: relative;
    width: var(--avatar-size, 160px);
    height: var(--avatar-size, 160px);
    overflow: hidden;
    border: var(--avatar-border, 2px solid hsl(var(--border)));
    border-radius: 50%;
    background: hsl(var(--background));
    box-shadow: var(--avatar-shadow, none);
    filter: var(--avatar-filter, saturate(1.50) contrast(1));
  }

  .avatar-media__poster,
  .avatar-media__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    margin: 0;
    border: 0;
    display: block;
    object-fit: cover;
  }

  .avatar-media__poster {
    z-index: 1;
  }

  .avatar-media__video {
    z-index: 2;
    opacity: 0;
  }

  .avatar-media.is-video-ready [data-avatar-random-video],
  .avatar-media.is-hover-video-ready [data-avatar-hover-video] {
    opacity: 1;
  }
</style>
