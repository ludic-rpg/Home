---
const { id, title = 'Video', minimal = false, params } = Astro.props;

const playerParams = new URLSearchParams(params || '');

if (minimal) {
  playerParams.set('rel', playerParams.get('rel') || '0');
  playerParams.set('modestbranding', playerParams.get('modestbranding') || '1');
  playerParams.set('iv_load_policy', playerParams.get('iv_load_policy') || '3');
}

const paramsString = playerParams.toString();
const embedParams = paramsString ? `?${paramsString}` : '';
---

<div class="video-frame-container">
  <iframe
    src={`https://www.youtube-nocookie.com/embed/${id}${embedParams}`}
    title={title}
    frameborder="0"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    allowfullscreen
    loading="lazy"
  ></iframe>
</div>

<style>
  .video-frame-container {
    position: relative;
    height: 0;
    overflow: hidden;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    margin: 2rem 0;
    border: 1px solid hsl(var(--border));
    background-color: hsl(var(--background));
  }

  .video-frame-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  @media (max-width: 768px) {
    .video-frame-container {
      margin: 1.5rem 0;
    }
  }
</style>
