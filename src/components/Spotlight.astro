---
interface Props {
  title: string;
  description: string;
  imageSrc?: string;
  imageAlt?: string;
  primaryCTA: { label: string; href: string; external?: boolean };
  secondaryCTA?: { label: string; href: string; external?: boolean };
  glowColor: 'green' | 'blue' | 'purple' | 'cyan';
  imagePosition?: 'left' | 'right';
  id?: string;
}

const {
  title,
  description,
  imageSrc,
  imageAlt,
  primaryCTA,
  secondaryCTA,
  glowColor,
  imagePosition = 'left',
  id
} = Astro.props;

const glowClass = `glow-${glowColor}`;
---

<section class={`spotlight wireframe-border ${glowClass}`} id={id}>
  <div class={`spotlight-grid ${imagePosition === 'right' ? 'image-right' : ''}`}>

    {imageSrc && (
      <div class="spotlight-image">
        <img src={imageSrc} alt={imageAlt || title} loading="lazy" />
      </div>
    )}

    <div class="spotlight-text">
      <h2>{title}</h2>
      <p class="description">{description}</p>

      <div class="spotlight-ctas">
        <a
          href={primaryCTA.href}
          class="cta primary"
          target={primaryCTA.external ? '_blank' : undefined}
          rel={primaryCTA.external ? 'noopener noreferrer' : undefined}
        >
          {primaryCTA.label}
          {primaryCTA.external && ' ↗'}
        </a>
        {secondaryCTA && (
          <a
            href={secondaryCTA.href}
            class="cta secondary"
            target={secondaryCTA.external ? '_blank' : undefined}
            rel={secondaryCTA.external ? 'noopener noreferrer' : undefined}
          >
            {secondaryCTA.label}
            {secondaryCTA.external && ' ↗'}
          </a>
        )}
      </div>
    </div>

  </div>
</section>

<style>
  /* ===== MOBILE (Default) ===== */
  .spotlight {
    padding: 0;
    overflow: hidden;
  }

  .spotlight-grid {
    display: grid;
    grid-template-areas:
      "image"
      "text";
    gap: 0;
  }

  .spotlight-image {
    grid-area: image;
  }

  .spotlight-image img {
    width: 100%;
    height: auto;
    max-height: 300px;
    object-fit: cover;
    object-position: center;
    border: none;
    border-bottom: 1px solid hsl(var(--border));
    display: block;
    transition: transform 0.3s ease;
  }

  .spotlight-text {
    grid-area: text;
    padding: 1.5rem;
  }

  .spotlight-text h2 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    text-wrap: balance;
  }

  .description {
    font-size: 0.95rem;
    line-height: 1.6;
    color: hsl(var(--body-text));
    margin-bottom: 1.25rem;
    text-wrap: balance;
  }

  .spotlight-ctas {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cta {
    display: inline-block;
    padding: 0.625rem 1.25rem;
    text-align: center;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9rem;
    border: 1px solid hsl(var(--border));
    transition: all 0.2s ease;
  }

  .cta.primary {
    background: rgba(255, 255, 255, 0.1);
    color: hsl(var(--foreground));
  }

  .cta.secondary {
    background: transparent;
    color: hsl(var(--muted-foreground));
  }

  .cta:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: hsl(var(--foreground));
    color: hsl(var(--foreground));
  }

  /* ===== TABLET (768px - 1023px) ===== */
  @media (min-width: 768px) {
    .spotlight-grid {
      display: grid;
      grid-template-columns: 1fr 1.5fr;
      grid-template-rows: auto;
      grid-template-areas: "image text";
    }

    /* Alternate image position */
    .spotlight-grid.image-right {
      grid-template-columns: 1.5fr 1fr;
      grid-template-areas: "text image";
    }

    .spotlight-image {
      overflow: hidden;
      position: relative;
      min-height: 0;
      align-self: stretch;
    }

    .spotlight-image img {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      max-height: none;
      object-fit: cover;
      object-position: center;
      border-bottom: none;
      border-right: 1px solid hsl(var(--border));
    }

    .spotlight-grid.image-right .spotlight-image img {
      border-right: none;
      border-left: 1px solid hsl(var(--border));
    }

    .spotlight-text {
      padding: 1.5rem 2rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .spotlight-text h2 {
      font-size: 1.625rem;
    }
  }

  /* ===== DESKTOP (Enriched) ===== */
  @media (min-width: 1024px) {
    .spotlight {
      padding: 0;
    }

    .spotlight-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
      grid-template-areas: "image text";
    }

    /* Alternate image position */
    .spotlight-grid.image-right {
      grid-template-areas: "text image";
    }

    .spotlight-image {
      grid-area: image;
      overflow: hidden;
      position: relative;
      min-height: 0;
      align-self: stretch;
    }

    .spotlight-text {
      grid-area: text;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .spotlight-image img {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      border: none;
      border-right: 1px solid hsl(var(--border));
      display: block;
    }

    .spotlight-grid.image-right .spotlight-image img {
      border-right: none;
      border-left: 1px solid hsl(var(--border));
    }

    .spotlight-image img:hover {
      transform: scale(1.02);
    }

    .spotlight-text {
      padding: 1.5rem 2.5rem;
    }

    .spotlight-text h2 {
      font-size: 1.75rem;
    }

    .spotlight-ctas {
      flex-direction: row;
    }
  }
</style>
