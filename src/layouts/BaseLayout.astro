---
import SiteHeader from '../components/SiteHeader.astro';
import Footer from '../components/Footer.astro';
import type { NavBehavior } from '../types/navigation';

// When the calling page is a blog post, pass `article` with publishedTime,
// optional modifiedTime, author, section, tags. Presence of `article` flips
// og:type to "article", emits article:* meta, and swaps the JSON-LD over to
// BlogPosting so Google can show rich article results.
const { title, description, ogImage, canonical, article, navBehavior = 'sticky' } = Astro.props;

const SITE = 'https://ludicrpg.com';
const DEFAULT_OG_IMAGE = `${SITE}/assets/ludic-rpg-logo.webp`;
const DEFAULT_OG_ALT = 'Ludic RPG Logo - Tabletop RPG Designer and Content Creator';

// Normalize to absolute URL — many social crawlers reject relative og:image.
const ogImageUrl = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${SITE}${ogImage.startsWith('/') ? '' : '/'}${ogImage}`)
  : DEFAULT_OG_IMAGE;
const ogImageAlt = article ? title : DEFAULT_OG_ALT;
const ogType = article ? 'article' : 'website';

const jsonLd = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      'headline': title,
      'description': description,
      'url': canonical,
      'image': ogImageUrl,
      'datePublished': article.publishedTime,
      'dateModified': article.modifiedTime || article.publishedTime,
      'author': {
        '@type': 'Person',
        'name': article.author || 'Ludovic Fleury',
        'url': SITE,
      },
      'publisher': {
        '@type': 'Organization',
        'name': 'Ludic RPG',
        'url': SITE,
        'logo': {
          '@type': 'ImageObject',
          'url': DEFAULT_OG_IMAGE,
        },
        // sameAs lets Google associate this brand with the social presence.
        'sameAs': [
          'https://discord.gg/WYQMvQcYgP',
          'https://reddit.com/r/ludicRPG',
          'https://youtube.com/@ludicRPG',
        ],
      },
      'mainEntityOfPage': {
        '@type': 'WebPage',
        '@id': canonical,
      },
      'keywords': (article.tags || []).join(', '),
      'articleSection': article.section || 'Blog',
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      'name': title,
      'url': canonical,
      'about': {
        '@type': 'CreativeWork',
        'name': 'Ludic RPG',
        'url': SITE,
      },
      'description': description,
    };
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="author" content={article?.author || 'Ludic RPG'}>
    <meta name="robots" content="index, follow">
    <meta name="theme-color" content="#0d0d0d">
    <meta name="color-scheme" content="dark">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType}>
    <meta property="og:url" content={canonical}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content={ogImageUrl}>
    <meta property="og:image:alt" content={ogImageAlt}>
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:site_name" content="Ludic RPG">

    {article && (
      <>
        <meta property="article:published_time" content={article.publishedTime} />
        {article.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime} />}
        <meta property="article:author" content={article.author || 'Ludovic Fleury'} />
        <meta property="article:section" content={article.section || 'Blog'} />
        {(article.tags || []).map((tag) => (
          <meta property="article:tag" content={tag} />
        ))}
      </>
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content={canonical}>
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={ogImageUrl}>
    <meta name="twitter:image:alt" content={ogImageAlt}>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonical}>

    <!-- RSS auto-discovery -->
    <link rel="alternate" type="application/rss+xml" title="Ludic RPG Blog" href="/rss.xml">

    <!-- Preload critical images -->
    <link rel="preload" as="image" href="/assets/ludic-rpg-logo.webp" type="image/webp">

    <!-- Favicon and touch icons -->
    <link rel="icon" type="image/png" href="/assets/ludic-rpg-logo.png">
    <link rel="apple-touch-icon" href="/assets/ludic-rpg-logo.png">
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Fathom (privacy-first analytics) - only in production -->
    {import.meta.env.PROD && (
        <script src="https://cdn.usefathom.com/script.js" data-site="PSLRUBJE" defer></script>
    )}
</head>
<body>
    <SiteHeader behavior={navBehavior} />
    <slot />
    <Footer />
</body>
</html>
