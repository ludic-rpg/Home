---
import BaseLayout from './BaseLayout.astro';
import YouTubeFacade from '../components/youtube/Facade.astro';
import Avatar from '../components/Avatar.astro';
import { resolveBlogAsset } from '../lib/blog/posts';
import { extractYouTubeId } from '../lib/seo/youtube';

type ContentSegment =
  | { type: 'html'; html: string }
  | { type: 'youtube'; id: string; title: string; poster?: string };

const { frontmatter, slug, articleEntry } = Astro.props;
const {
  title,
  description,
  publishDate,
  coverImage,
  videoUrl,
  videoTitle,
  videoDescription,
  videoUploadDate,
  videoDuration,
  tags = [],
} = frontmatter;
const pageTitle = `${title} | Ludic RPG Blog`;

const ambientAvatarVideos = [
  '/assets/video/avatar/avatar-dog-angry.mp4',
  '/assets/video/avatar/avatar-dog-curious-ear.mp4',
  '/assets/video/avatar/avatar-wind-hair.mp4',
  '/assets/video/avatar/avatar-dog-look-right-a.mp4',
  '/assets/video/avatar/avatar-dog-look-right-b.mp4',
];

// Extract YouTube video ID from videoUrl
const videoId = videoUrl ? extractYouTubeId(videoUrl) : null;

// Calculate reading time (rough estimate: 200 words per minute)
const content = await Astro.slots.render('default');
const wordCount = content.split(/\s+/).length;
const readingTime = Math.ceil(wordCount / 200);
const hasImagePair = /<p>\s*(?:<img\b[^>]*>\s*){2}<\/p>/.test(content);
const contentSegments = segmentInlineYouTubeEmbeds(content);

// Format date
const formattedDate = new Date(publishDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Glow colors removed for distraction-free reading

const canonical = `https://ludicrpg.com/blog/${slug}/`;

const publishedISO = new Date(publishDate).toISOString();
const videoUploadISO = videoUploadDate ? new Date(videoUploadDate).toISOString() : undefined;
const breadcrumbs = [
  { name: 'Home', url: 'https://ludicrpg.com/' },
  { name: 'Blog', url: 'https://ludicrpg.com/blog/' },
  { name: title, url: canonical },
];

function decodeAttribute(value: string): string {
  return value
    .replace(/&amp;/g, '&')
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&#x27;/g, "'")
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>');
}

function attributeValue(source: string, name: string): string | undefined {
  const match = source.match(new RegExp(`${name}=["']([^"']*)["']`, 'i'));
  return match ? decodeAttribute(match[1]) : undefined;
}

function inlineYouTubePoster(videoId: string): string | undefined {
  if (!articleEntry) return undefined;
  return resolveBlogAsset(articleEntry, `./assets/youtube-${videoId}.webp`);
}

function segmentInlineYouTubeEmbeds(html: string): ContentSegment[] {
  const segments: ContentSegment[] = [];
  const embedPattern = /<p>\s*(<img\b[^>]*>)\s*<\/p>/gi;
  let cursor = 0;
  let match;

  while ((match = embedPattern.exec(html)) !== null) {
    const img = match[1];
    const src = attributeValue(img, 'src');
    const videoId = src ? extractYouTubeId(src) : null;

    if (!videoId) continue;

    if (match.index > cursor) {
      segments.push({ type: 'html', html: html.slice(cursor, match.index) });
    }

    segments.push({
      type: 'youtube',
      id: videoId,
      title: attributeValue(img, 'alt') || 'YouTube video',
      poster: inlineYouTubePoster(videoId),
    });

    cursor = match.index + match[0].length;
  }

  if (cursor < html.length) {
    segments.push({ type: 'html', html: html.slice(cursor) });
  }

  return segments.length ? segments : [{ type: 'html', html }];
}
---

<BaseLayout
  title={pageTitle}
  description={description}
  canonical={canonical}
  ogImage={coverImage}
  article={{
    headline: title,
    publishedTime: publishedISO,
    section: 'Blog',
    tags: tags,
    video: videoUrl
      ? {
          url: videoUrl,
          name: videoTitle || title,
          description: videoDescription || description,
          thumbnailUrl: coverImage,
          uploadDate: videoUploadISO || publishedISO,
          duration: videoDuration,
        }
      : undefined,
  }}
  breadcrumbs={breadcrumbs}
  navBehavior="auto-hide"
  headerClass="blog-post-cover-shadow"
>
  <div class="container blog-post-container">
    <article class="blog-post">
    <!-- Cover Media (Video or Image) - outside content padding -->
    {videoId ? (
      <div class="blog-cover-video">
        <YouTubeFacade id={videoId} title={title} poster={coverImage} minimal={true} />
      </div>
    ) : coverImage ? (
      <div class="blog-cover-image">
        <img src={coverImage} alt={title} loading="eager" fetchpriority="high" />
      </div>
    ) : null}

    <div class="prose-container">
      <!-- Post Header -->
      <header class="blog-post-header">
        <h1 class="blog-post-title">{title}</h1>
        <div class="blog-post-meta">
          <time datetime={publishDate.toISOString()}>{formattedDate}</time>
          <span class="meta-separator">•</span>
          <span>{readingTime} min read</span>
        </div>
      </header>

      <!-- Post Content -->
      <div class="prose">
        {contentSegments.map((segment) => (
          segment.type === 'youtube' ? (
            <YouTubeFacade id={segment.id} title={segment.title} poster={segment.poster} />
          ) : (
            <Fragment set:html={segment.html} />
          )
        ))}
      </div>

      <!-- Post Footer -->
      <footer class="blog-post-footer">
        <div class="blog-post-actions" data-blog-post-actions hidden={tags.length === 0}>
          {tags.length > 0 && (
            <nav class="blog-post-tags-footer" aria-label="Post tags">
              {tags.map((tag) => (
                <a href={`/blog/tags/${tag}`} class="tag">#{tag}</a>
              ))}
            </nav>
          )}

          <a
            href="https://www.reddit.com/r/ludicRPG/"
            target="_blank"
            rel="noopener noreferrer"
            class="blog-post-reddit-link"
            data-reddit-discussion
            data-reddit-slug={slug}
            aria-label="Upvote this post on Reddit"
            hidden
          >
            <svg class="reddit-upvote-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M12 3.5 4.25 12.75h4.25V20.5h7v-7.75h4.25L12 3.5Z" />
            </svg>
            <span class="reddit-upvote-copy" data-reddit-score>Upvote on Reddit</span>
            <span class="reddit-comment-stat" data-reddit-comment-stat hidden>
              <svg class="reddit-comment-icon" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
                <path d="M10 3.25c-4.1 0-7.25 2.54-7.25 5.86 0 1.95 1.08 3.65 2.8 4.71l-.52 2.25 2.55-1.24c.75.18 1.56.27 2.42.27 4.1 0 7.25-2.54 7.25-5.99S14.1 3.25 10 3.25Z" />
              </svg>
              <span data-reddit-comments></span>
            </span>
          </a>
        </div>

        <section class="blog-post-signature" aria-label="Author sign-off">
          <div class="blog-post-signature-bubble">
            <span>Thank you for reading!</span>
          </div>
          <Avatar
            class="blog-post-signature-avatar"
            chance={0.2}
            hoverVideoSrc="/assets/video/avatar/avatar-dog-happy-owner.mp4"
            loading="lazy"
            videoSrcs={ambientAvatarVideos}
          />
        </section>
      </footer>
    </div>
  </article>
  </div>

  {hasImagePair && (
    <script>
      import '../scripts/prose-image-pair';
    </script>
  )}

  <script>
    const header = document.getElementById('site-header');
    const cover = document.querySelector<HTMLElement>('.blog-cover-video, .blog-cover-image');

    if (header && cover) {
      const updateCoverShadow = () => {
        const fadeDistance = cover.offsetHeight * 0.28;
        const progress = Math.min(window.scrollY / fadeDistance, 1);
        header.style.setProperty('--site-header-shadow-progress', progress.toFixed(3));
      };

      updateCoverShadow();

      window.addEventListener('scroll', updateCoverShadow, { passive: true });
      window.addEventListener('resize', updateCoverShadow);
      window.addEventListener('beforeunload', () => {
        window.removeEventListener('scroll', updateCoverShadow);
        window.removeEventListener('resize', updateCoverShadow);
      });
    } else if (header) {
      header.style.setProperty('--site-header-shadow-progress', '1');
    }
  </script>

  <script>
    const redditLinks = document.querySelectorAll<HTMLAnchorElement>('[data-reddit-discussion]');

    const formatCompactNumber = (value: number) => new Intl.NumberFormat('en', {
      notation: value >= 1000 ? 'compact' : 'standard',
      maximumFractionDigits: 1,
    }).format(value);

    const formatUpvoteLabel = (score: number) => {
      const compact = formatCompactNumber(score);
      const noun = score === 1 ? 'upvote' : 'upvotes';
      return `${compact} ${noun}`;
    };

    const formatCommentLabel = (count: number) => {
      const compact = formatCompactNumber(count);
      const noun = count === 1 ? 'comment' : 'comments';
      return `${compact} ${noun}`;
    };

    const loadRedditDiscussion = async (link: HTMLAnchorElement) => {
      const scoreLabelEl = link.querySelector<HTMLElement>('[data-reddit-score]');
      const commentStat = link.querySelector<HTMLElement>('[data-reddit-comment-stat]');
      const commentLabelEl = link.querySelector<HTMLElement>('[data-reddit-comments]');
      const slug = link.dataset.redditSlug;
      if (!scoreLabelEl || !slug) return;

      try {
        const response = await fetch(`/api/reddit-discussion/${slug}`, {
          headers: { Accept: 'application/json' },
        });
        if (!response.ok) return;

        const discussion = await response.json();
        const score = Number(discussion.score);
        const comments = Number(discussion.comments);
        if (!discussion.redditUrl || !Number.isFinite(score) || !Number.isFinite(comments)) return;

        const scoreLabel = formatUpvoteLabel(score);
        const commentLabel = formatCommentLabel(comments);
        link.href = discussion.redditUrl;
        scoreLabelEl.textContent = scoreLabel;
        scoreLabelEl.dataset.redditCompactLabel = formatCompactNumber(score);
        if (commentStat && commentLabelEl) {
          commentLabelEl.textContent = commentLabel;
          commentLabelEl.dataset.redditCompactLabel = formatCompactNumber(comments);
          commentStat.hidden = false;
        }
        link.hidden = false;
        link.closest<HTMLElement>('[data-blog-post-actions]')?.removeAttribute('hidden');
        link.setAttribute('aria-label', `${scoreLabel} and ${commentLabel} on Reddit. Open Reddit to upvote or comment on this post.`);
      } catch {}
    };

    redditLinks.forEach((link) => {
      loadRedditDiscussion(link);
    });
  </script>
</BaseLayout>

<style>
/* ========================================
   BLOG POST LAYOUT - ISOLATED STYLES
   ======================================== */

/* Layout Structure */
.blog-post-container {
    padding-top: 0;
}

:global(.site-header.blog-post-cover-shadow) {
    --site-header-shadow-progress: 0;
    transition:
        transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.blog-post {
    position: relative;
    isolation: isolate;
    --blog-header-decoration-offset: 6.75rem;
    --blog-header-grid-size: 24px;
    --blog-header-grid-base-line:
        linear-gradient(to bottom, rgb(255 255 255 / 0.045) 1px, transparent 1px),
        linear-gradient(90deg, rgb(255 255 255 / 0.045) 1px, transparent 1px);
    --blog-header-grid-patch-line:
        linear-gradient(to bottom, rgb(255 255 255 / 0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgb(255 255 255 / 0.035) 1px, transparent 1px);
    --blog-header-grid-fade-mask:
        radial-gradient(ellipse 88rem 54rem at 50% 14rem, black 0%, rgb(0 0 0 / 0.78) 30%, rgb(0 0 0 / 0.42) 58%, rgb(0 0 0 / 0.08) 82%, transparent 100%),
        linear-gradient(to bottom, black 0%, black 66%, rgb(0 0 0 / 0.45) 84%, transparent 100%);
    --blog-header-grid-patch-mask:
        radial-gradient(ellipse 34rem 18rem at 22% 9rem, rgb(0 0 0 / 0.68) 0%, rgb(0 0 0 / 0.46) 34%, transparent 76%),
        radial-gradient(ellipse 24rem 16rem at 66% 7rem, rgb(0 0 0 / 0.58) 0%, rgb(0 0 0 / 0.38) 38%, transparent 78%),
        radial-gradient(ellipse 38rem 22rem at 82% 24rem, rgb(0 0 0 / 0.6) 0%, rgb(0 0 0 / 0.4) 32%, transparent 74%),
        radial-gradient(ellipse 26rem 20rem at 38% 32rem, rgb(0 0 0 / 0.5) 0%, rgb(0 0 0 / 0.32) 34%, transparent 82%);
    padding: 0;
    overflow: visible;
}

.blog-post::before,
.blog-post::after {
    content: "";
    position: absolute;
    display: none;
    top: calc(-1 * var(--blog-header-decoration-offset));
    left: 50%;
    width: 100vw;
    height: calc(clamp(30rem, 64vw, 43rem) + var(--blog-header-decoration-offset));
    transform: translateX(-50%);
    pointer-events: none;
}

.blog-post::before {
    z-index: 1;
    background-image: var(--blog-header-grid-patch-line);
    background-size: var(--blog-header-grid-size) var(--blog-header-grid-size);
    -webkit-mask-image: var(--blog-header-grid-patch-mask);
    mask-image: var(--blog-header-grid-patch-mask);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
}

.blog-post::after {
    z-index: 0;
    background-image: var(--blog-header-grid-base-line);
    background-size: var(--blog-header-grid-size) var(--blog-header-grid-size);
    -webkit-mask-image: var(--blog-header-grid-fade-mask);
    mask-image: var(--blog-header-grid-fade-mask);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-composite: source-in;
    mask-composite: intersect;
}

.blog-post > .prose-container {
    position: relative;
    z-index: 2;
}

/* Cover Media */
.blog-cover-image,
.blog-cover-video {
    position: relative;
    z-index: 1;
    width: 100%;
    aspect-ratio: 2 / 1;
    overflow: hidden;
    background: hsl(var(--accent));
    box-shadow:
        -2.5rem -1.5rem 6rem rgb(0 0 0 / 0.48),
        2.5rem -1.5rem 6rem rgb(0 0 0 / 0.48),
        0 -1.25rem 5rem rgb(0 0 0 / 0.42),
        0 2.5rem 8rem rgb(0 0 0 / 0.58),
        0 0 10rem rgb(0 0 0 / 0.42);
}

.blog-cover-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.blog-cover-video :global(.video-container) {
    height: 100%;
    margin: 0 !important;
    border: none !important;
}

.blog-cover-video :global(.youtube-facade),
.blog-cover-video :global(.video-container iframe) {
    height: 100%;
    aspect-ratio: auto;
}

/* Post Header */
.blog-post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid hsl(var(--border));
}

.blog-post-title {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1rem;
    color: hsl(var(--foreground));
    text-wrap: pretty;
}

.blog-post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Courier New', monospace;
    font-size: 0.8125rem;
    color: hsl(var(--muted-foreground));
    margin-bottom: 1rem;
}

.meta-separator {
    color: hsl(var(--border));
}

.blog-post-actions {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 0;
}

.blog-post-actions[hidden],
.blog-post-reddit-link[hidden],
.reddit-comment-stat[hidden] {
    display: none;
}

.blog-post-actions::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.42) 0%,
        rgba(255, 255, 255, 0.16) 42%,
        rgba(255, 255, 255, 0) 100%
    );
    pointer-events: none;
}

.blog-post-tags-footer {
    display: flex;
    flex: 1 1 auto;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.75rem;
    min-width: 0;
}

.blog-post-tags-footer .tag {
    display: inline-flex;
    align-items: center;
    padding: 0;
    min-height: 0;
    font-size: 0.75rem;
    font-weight: 500;
    color: hsl(var(--muted-foreground));
    background: transparent;
    border: 0;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s ease, opacity 0.15s ease;
}

.blog-post-tags-footer .tag:hover,
.blog-post-tags-footer .tag:focus-visible {
    color: hsl(var(--foreground));
    background: transparent;
    border: 0;
}

.blog-post-reddit-link {
    --reddit-accent: #ff4500;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    gap: 0.42rem;
    min-height: 1.75rem;
    padding: 0.22rem 0;
    color: hsl(var(--foreground));
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1;
    text-decoration: none;
    text-underline-offset: 3px;
    white-space: nowrap;
}

.blog-post-reddit-link:hover,
.blog-post-reddit-link:focus-visible {
    text-decoration: underline;
}

.reddit-upvote-icon,
.reddit-comment-icon {
    width: 1rem;
    height: 1rem;
    color: var(--reddit-accent);
    transform: translateY(-0.015rem);
}

.reddit-upvote-icon path,
.reddit-comment-icon path {
    fill: transparent;
    stroke: currentColor;
    stroke-width: 1.75;
    stroke-linejoin: round;
    transition: fill 0.15s ease;
}

.blog-post-reddit-link:hover .reddit-upvote-icon path,
.blog-post-reddit-link:focus-visible .reddit-upvote-icon path,
.blog-post-reddit-link:hover .reddit-comment-icon path,
.blog-post-reddit-link:focus-visible .reddit-comment-icon path {
    fill: currentColor;
}

.reddit-comment-stat {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    margin-left: 0.16rem;
}

/* Post Footer */
.blog-post-footer {
    margin-top: 4rem;
    padding-top: 0;
}

.blog-post-signature {
    --signature-avatar-size: clamp(4.25rem, 11vw, 6rem);
    display: grid;
    grid-template-columns: minmax(0, auto) var(--signature-avatar-size);
    justify-content: end;
    align-items: center;
    gap: 1.125rem;
    margin-top: 2rem;
}

.blog-post-signature-bubble {
    position: relative;
    isolation: isolate;
    display: inline-flex;
    align-items: center;
    min-height: 3rem;
    padding: 0.8rem 1rem 0.68rem;
    color: hsl(var(--background));
    font-family: 'Bangers', cursive;
    font-size: clamp(1.35rem, 4vw, 2rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0.02em;
    text-align: center;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.9);
    white-space: nowrap;
    transform: translateY(-25px);
    z-index: 3;
}

.blog-post-signature-bubble::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
        90deg,
        hsl(0 0% 50%) 0%,
        hsl(0 0% 96%) 30%,
        hsl(0 0% 96%) 100%
    );
    z-index: 2;
    pointer-events: none;
}

.blog-post-signature-bubble span {
    position: relative;
    z-index: 3;
}

.blog-post-signature-bubble::after {
    content: '';
    position: absolute;
    right: -24px;
    top: calc(50% - 0.35rem);
    width: 0;
    height: 0;
    transform: translateY(-50%) skewY(28deg);
    transform-origin: left center;
    border-left: 42px solid hsl(0 0% 96%);
    border-top: 18px solid transparent;
    border-bottom: 18px solid transparent;
    filter: drop-shadow(3px 2px 4px rgba(0, 0, 0, 0.25));
    z-index: 1;
    pointer-events: none;
}

.blog-post-signature :global(.blog-post-signature-avatar) {
    --avatar-size: var(--signature-avatar-size);
    --avatar-border: none;
    --avatar-shadow: 0 4px 12px rgba(0, 0, 0, 0.5);
    position: relative;
    z-index: 1;
}

/* ========================================
   RESPONSIVE
   ======================================== */

/* Mobile - Reduce font sizes */
@media (max-width: 768px) {
    .blog-post-title {
        font-size: 1.75rem;
    }

    .blog-post-signature {
        --signature-avatar-size: clamp(3.75rem, 18vw, 5rem);
        gap: 0.85rem;
    }

    .blog-post-signature-bubble {
        padding: 0.7rem 0.85rem 0.6rem;
        font-size: clamp(1.15rem, 6vw, 1.6rem);
    }

    .blog-post-signature-bubble::after {
        right: -18px;
        border-left-width: 30px;
        border-top-width: 14px;
        border-bottom-width: 14px;
    }

    .blog-post-actions {
        align-items: flex-start;
    }

    .blog-post-reddit-link {
        min-height: 1.55rem;
    }

    .reddit-upvote-copy {
        font-size: 0;
    }

    .reddit-upvote-copy::before {
        content: attr(data-reddit-compact-label);
        font-size: 0.75rem;
    }

    .reddit-comment-stat {
        gap: 0.22rem;
        margin-left: 0.1rem;
    }

    .reddit-comment-stat [data-reddit-comments] {
        font-size: 0;
    }

    .reddit-comment-stat [data-reddit-comments]::before {
        content: attr(data-reddit-compact-label);
        font-size: 0.75rem;
    }

}

@media (min-width: 769px) {
    .blog-post::before,
    .blog-post::after {
        display: block;
    }
}
</style>
