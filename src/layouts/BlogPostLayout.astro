---
import BaseLayout from './BaseLayout.astro';
import YouTube from '../components/YouTube.astro';
import AvatarMedia from '../components/AvatarMedia.astro';
import { extractYouTubeId } from '../lib/seo/youtube';

const { frontmatter, slug } = Astro.props;
const {
  title,
  description,
  publishDate,
  coverImage,
  videoUrl,
  videoTitle,
  videoDescription,
  videoUploadDate,
  videoDuration,
  tags = [],
} = frontmatter;
const pageTitle = `${title} | Ludic RPG Blog`;

const ambientAvatarVideos = [
  '/assets/video/avatar/avatar-dog-angry.mp4',
  '/assets/video/avatar/avatar-dog-curious-ear.mp4',
  '/assets/video/avatar/avatar-wind-hair.mp4',
  '/assets/video/avatar/avatar-dog-look-right-a.mp4',
  '/assets/video/avatar/avatar-dog-look-right-b.mp4',
];

// Extract YouTube video ID from videoUrl
const videoId = videoUrl ? extractYouTubeId(videoUrl) : null;

// Calculate reading time (rough estimate: 200 words per minute)
const content = await Astro.slots.render('default');
const wordCount = content.split(/\s+/).length;
const readingTime = Math.ceil(wordCount / 200);

// Format date
const formattedDate = new Date(publishDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Glow colors removed for distraction-free reading

const canonical = `https://ludicrpg.com/blog/${slug}/`;

const publishedISO = new Date(publishDate).toISOString();
const videoUploadISO = videoUploadDate ? new Date(videoUploadDate).toISOString() : undefined;
const breadcrumbs = [
  { name: 'Home', url: 'https://ludicrpg.com/' },
  { name: 'Blog', url: 'https://ludicrpg.com/blog/' },
  { name: title, url: canonical },
];
---

<BaseLayout
  title={pageTitle}
  description={description}
  canonical={canonical}
  ogImage={coverImage}
  article={{
    headline: title,
    publishedTime: publishedISO,
    section: 'Blog',
    tags: tags,
    video: videoUrl
      ? {
          url: videoUrl,
          name: videoTitle || title,
          description: videoDescription || description,
          thumbnailUrl: coverImage,
          uploadDate: videoUploadISO || publishedISO,
          duration: videoDuration,
        }
      : undefined,
  }}
  breadcrumbs={breadcrumbs}
  navBehavior="auto-hide"
>
  <div class="container blog-post-container">
    <div class="space-y-16">
      <!-- Blog Post -->
      <article class="blog-post">
    <!-- Cover Media (Video or Image) - outside content padding -->
    {videoId ? (
      <div class="blog-cover-video">
        <YouTube id={videoId} title={title} minimal={true} />
      </div>
    ) : coverImage ? (
      <div class="blog-cover-image">
        <img src={coverImage} alt={title} loading="eager" fetchpriority="high" />
      </div>
    ) : null}

    <div class="blog-post-content">
      <div class="blog-post-inner">
        <!-- Post Header -->
        <header class="blog-post-header">
          <h1 class="blog-post-title">{title}</h1>
          <div class="blog-post-meta">
            <time datetime={publishDate.toISOString()}>{formattedDate}</time>
            <span class="meta-separator">•</span>
            <span>{readingTime} min read</span>
          </div>
        </header>

        <!-- Post Content -->
        <div class="blog-post-body prose">
          <slot />
        </div>

        <!-- Post Footer -->
        <footer class="blog-post-footer">
        <!-- Tags -->
        {tags.length > 0 && (
          <nav class="blog-post-tags-footer" aria-label="Post tags">
            {tags.map((tag) => (
              <a href={`/blog/tags/${tag}`} class="tag">#{tag}</a>
            ))}
          </nav>
        )}

        <section class="blog-post-signature" aria-label="Author sign-off">
          <div class="blog-post-signature-bubble">
            <span>Thank you for reading!</span>
          </div>
          <AvatarMedia
            class="blog-post-signature-avatar"
            chance={0.2}
            hoverVideoSrc="/assets/video/avatar/avatar-dog-happy-owner.mp4"
            loading="lazy"
            videoSrcs={ambientAvatarVideos}
          />
        </section>
      </footer>
      </div>
    </div>
  </article>
    </div>
  </div>
</BaseLayout>

<style>
/* ========================================
   BLOG POST LAYOUT - ISOLATED STYLES
   ======================================== */

/* Layout Structure */
.blog-post {
    padding: 0;
    overflow: hidden;
}

.blog-post-content {
    padding: 2rem;
}

.blog-post-inner {
    max-width: 680px;
    margin: 0 auto;
}

/* Cover Media */
.blog-cover-image,
.blog-cover-video {
    width: 100%;
    aspect-ratio: 2 / 1;
    overflow: hidden;
    background: hsl(var(--accent));
}

.blog-cover-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.blog-cover-video :global(.video-container) {
    margin: 0 !important;
    padding-bottom: 50% !important;
    border: none !important;
}

/* Post Header */
.blog-post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid hsl(var(--border));
}

.blog-post-title {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1rem;
    color: hsl(var(--foreground));
    text-wrap: pretty;
}

.blog-post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 0.8125rem;
    color: hsl(var(--muted-foreground));
    margin-bottom: 1rem;
}

.meta-separator {
    color: hsl(var(--border));
}

.blog-post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}

.blog-post-tags-footer {
    position: relative;
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 0;
}

.blog-post-tags-footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.42) 0%,
        rgba(255, 255, 255, 0.16) 42%,
        rgba(255, 255, 255, 0) 100%
    );
    pointer-events: none;
}

.blog-post-tags-footer .tag {
    display: inline;
    padding: 0;
    min-height: 0;
    font-size: 0.75rem;
    font-weight: 500;
    color: hsl(var(--muted-foreground));
    background: transparent;
    border: 0;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s ease, opacity 0.15s ease;
}

.blog-post-tags-footer .tag:hover,
.blog-post-tags-footer .tag:focus-visible {
    color: hsl(var(--foreground));
    background: transparent;
    border: 0;
}

/* Prose - Content Typography */
.prose {
    color: hsl(var(--foreground));
    font-size: 1.0625rem; /* 17px for long-form reading */
}

.prose > :global(p:first-of-type),
.prose > :global(h2:first-child + p),
.prose > :global(h3:first-child + p),
.prose > :global(h4:first-child + p) {
    font-size: 1.125rem;
    letter-spacing: 0.01em;
}

.prose :global(h2) {
    font-size: 2rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    color: hsl(var(--foreground));
    border-bottom: 1px solid hsl(var(--border));
    padding-bottom: 0.5rem;
}

.prose :global(h3) {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: hsl(var(--foreground));
}

.prose :global(h4) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: hsl(var(--foreground));
}

.prose :global(p) {
    margin-bottom: 2rem;
    color: hsl(var(--body-text));
    line-height: 1.5;
    text-wrap: pretty;
}

.prose :global(a) {
    color: inherit;
    text-decoration-line: underline;
    text-decoration-color: hsl(var(--link-underline));
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
    transition:
        color 0.18s ease,
        background-color 0.18s ease,
        text-decoration-color 0.18s ease;
}

.prose :global(a:visited) {
    color: inherit;
}

.prose :global(a:hover),
.prose :global(a:focus-visible) {
    color: hsl(var(--foreground));
    background-color: hsl(var(--link-highlight));
    text-decoration-color: hsl(var(--link-underline-hover));
}

.prose :global(strong) {
    font-weight: 600;
    color: hsl(var(--foreground));
}

.prose :global(em) {
    font-style: italic;
}

.prose :global(ul),
.prose :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
    color: hsl(var(--body-text));
}

.prose :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.75;
}

.prose :global(li::marker) {
    color: hsl(var(--border));
}

.prose :global(blockquote) {
    margin: 2rem 0;
    padding-left: 1.5rem;
    border-left: 4px solid hsl(var(--border));
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.6;
    color: hsl(var(--muted-foreground));
}

.prose :global(code) {
    padding: 0.2rem 0.4rem;
    font-size: 0.875em;
    font-family: 'Courier New', monospace;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid hsl(var(--border));
    border-radius: 3px;
    color: hsl(var(--foreground));
}

.prose :global(pre) {
    margin: 2rem 0;
    padding: 1.5rem;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid hsl(var(--border));
    overflow-x: auto;
}

.prose :global(pre code) {
    padding: 0;
    background: none;
    border: none;
    font-size: 0.875rem;
    line-height: 1.7;
}

.prose :global(img) {
    max-width: 100%;
    height: auto;
    margin: 2rem auto;
    border: 1px solid hsl(var(--border));
    display: block;
}

.prose :global(hr) {
    margin: 3rem 0;
    border: none;
    border-top: 1px solid hsl(var(--border));
}

/* Post Footer */
.blog-post-footer {
    margin-top: 4rem;
    padding-top: 0;
}

.blog-post-signature {
    --signature-avatar-size: clamp(4.25rem, 11vw, 6rem);
    display: grid;
    grid-template-columns: minmax(0, auto) var(--signature-avatar-size);
    justify-content: end;
    align-items: center;
    gap: 1.125rem;
    margin-top: 2rem;
}

.blog-post-signature-bubble {
    position: relative;
    isolation: isolate;
    display: inline-flex;
    align-items: center;
    min-height: 3rem;
    padding: 0.8rem 1rem 0.68rem;
    color: hsl(var(--background));
    font-family: 'Bangers', cursive;
    font-size: clamp(1.35rem, 4vw, 2rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0.02em;
    text-align: center;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.9);
    white-space: nowrap;
    transform: translateY(-25px);
    z-index: 3;
}

.blog-post-signature-bubble::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
        90deg,
        hsl(0 0% 50%) 0%,
        hsl(0 0% 96%) 30%,
        hsl(0 0% 96%) 100%
    );
    z-index: 2;
    pointer-events: none;
}

.blog-post-signature-bubble span {
    position: relative;
    z-index: 3;
}

.blog-post-signature-bubble::after {
    content: '';
    position: absolute;
    right: -24px;
    top: calc(50% - 0.35rem);
    width: 0;
    height: 0;
    transform: translateY(-50%) skewY(28deg);
    transform-origin: left center;
    border-left: 42px solid hsl(0 0% 96%);
    border-top: 18px solid transparent;
    border-bottom: 18px solid transparent;
    filter: drop-shadow(3px 2px 4px rgba(0, 0, 0, 0.25));
    z-index: 1;
    pointer-events: none;
}

.blog-post-signature :global(.blog-post-signature-avatar) {
    --avatar-size: var(--signature-avatar-size);
    --avatar-border: none;
    --avatar-shadow: 0 4px 12px rgba(0, 0, 0, 0.5);
    position: relative;
    z-index: 1;
}

/* ========================================
   RESPONSIVE
   ======================================== */

/* Large phones and small tablets - Optimize character count */
@media (min-width: 390px) and (max-width: 768px) {
    .blog-post-content {
        padding: 1.5rem 2rem;
    }
}

/* Mobile - Reduce font sizes */
@media (max-width: 768px) {
    .blog-post-content {
        padding: 1.5rem;
    }

    .blog-post-title {
        font-size: 1.75rem;
    }

    .blog-post-signature {
        --signature-avatar-size: clamp(3.75rem, 18vw, 5rem);
        gap: 0.85rem;
    }

    .blog-post-signature-bubble {
        padding: 0.7rem 0.85rem 0.6rem;
        font-size: clamp(1.15rem, 6vw, 1.6rem);
    }

    .blog-post-signature-bubble::after {
        right: -18px;
        border-left-width: 30px;
        border-top-width: 14px;
        border-bottom-width: 14px;
    }

    .prose :global(p) {
        margin-bottom: 1.25rem; /* 20px paragraph spacing for mobile */
    }

    /* Reduce list padding on mobile, but keep nested lists indented */
    .prose :global(ul),
    .prose :global(ol) {
        padding-left: 1.25rem; /* 20px instead of 32px for first level */
    }

    .prose :global(li ul),
    .prose :global(li ol) {
        padding-left: 1.5rem; /* Nested lists get additional indent */
    }

    .prose :global(h2) {
        font-size: 1.5rem;
    }

    .prose :global(h3) {
        font-size: 1.25rem;
    }
}
</style>
