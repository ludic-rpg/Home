---
import MarkdownLayout from './MarkdownLayout.astro';
import Avatar from '../components/Avatar.astro';

const { frontmatter } = Astro.props;

const ambientAvatarVideos = [
  '/assets/video/avatar/avatar-dog-angry.mp4',
  '/assets/video/avatar/avatar-dog-curious-ear.mp4',
  '/assets/video/avatar/avatar-wind-hair.mp4',
  '/assets/video/avatar/avatar-dog-look-right-a.mp4',
  '/assets/video/avatar/avatar-dog-look-right-b.mp4',
];
---

<script>
  import '../scripts/hero-animations';
</script>

<MarkdownLayout frontmatter={frontmatter} showPageHeader={false} navBehavior="auto-hide">
  <section class="about-section" aria-labelledby="hi-im-ludo">
    <div class="about-content prose">
      <Avatar
        class="about-avatar"
        chance={1}
        firstVideoSrc="/assets/video/avatar/avatar-about-first.mp4"
        hoverVideoSrc="/assets/video/avatar/avatar-dog-happy-owner.mp4"
        loading="eager"
        playImmediately
        videoSrcs={ambientAvatarVideos}
      />
      <slot />
    </div>
  </section>
</MarkdownLayout>

<style>
  .about-section {
    --about-content-width: 620px;
    --prose-max-width: var(--about-content-width);
    --about-padding-x: 0rem;
    --about-padding-y: 0rem;
    --about-title-size: 2.5rem;
    --about-avatar-size: clamp(4.95rem, 10.8vw, 9rem);
    --about-avatar-gap: clamp(0.875rem, 2vw, 1.5rem);
    --about-intro-gap: 2rem;
    --about-bubble-offset-y: -40px;
    position: relative;
    background: hsl(var(--background));
    padding: var(--about-padding-y) var(--about-padding-x) 2.5rem !important;
    margin-top: 2rem !important;
  }

  .about-content {
    display: grid;
    grid-template-columns: minmax(0, 1fr) var(--about-avatar-size) var(--about-avatar-gap) auto minmax(0, 1fr);
    column-gap: 0;
    row-gap: 0;
    align-items: start;
    position: relative;
  }

  .about-content > :global(h1:first-of-type) {
    grid-column: 4;
    display: inline-flex;
    align-items: center;
    justify-self: start;
    position: relative;
    isolation: isolate;
    z-index: 3;
    margin-top: 0;
    margin-bottom: 0;
    transform: translateY(var(--about-bubble-offset-y));
    border-bottom: none;
    color: hsl(var(--foreground));
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1;
    text-wrap: pretty;
  }

  .about-content > :global(h1:first-of-type),
  .about-content :global(.about-avatar) {
    opacity: 0;
  }

  .about-content :global(.about-avatar) {
    clip-path: circle(0% at center);
    transition: clip-path 0.3s ease-out, opacity 0.3s ease-out;
  }

  .about-content :global(.about-avatar.animate-in) {
    clip-path: circle(50% at center);
    opacity: 1;
  }

  @keyframes aboutBubblePopShake {
    0% {
      transform: translateY(var(--about-bubble-offset-y)) scale(0.8) rotate(0deg);
      opacity: 0;
    }
    60% {
      transform: translateY(var(--about-bubble-offset-y)) scale(1.05) rotate(2deg);
      opacity: 1;
    }
    80% {
      transform: translateY(var(--about-bubble-offset-y)) scale(0.98) rotate(-1deg);
    }
    100% {
      transform: translateY(var(--about-bubble-offset-y)) scale(1) rotate(0deg);
      opacity: 1;
    }
  }

  .about-content :global(:is(h1, h2):first-of-type.animate-in) {
    animation: aboutBubblePopShake 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55) 0.4s forwards;
  }

  .about-content :global(.about-avatar.no-motion) {
    clip-path: none;
    opacity: 1;
  }

  .about-content :global(:is(h1, h2):first-of-type.no-motion) {
    animation: none;
    opacity: 1;
    transform: translateY(var(--about-bubble-offset-y));
  }

  .about-content > :global(h1:first-of-type)::before {
    content: '';
    position: absolute;
    left: -26px;
    top: calc(50% - 1rem);
    width: 0;
    height: 0;
    transform: translateY(-50%) skewY(-34deg);
    transform-origin: right center;
    border-right: 50px solid hsl(0 0% 96%);
    border-top: 25px solid transparent;
    border-bottom: 25px solid transparent;
    filter: drop-shadow(-3px 2px 4px rgba(0, 0, 0, 0.3));
    z-index: -1;
    pointer-events: none;
  }

  .about-content :global(.about-title-bubble) {
    display: inline-block;
    padding: 1.25rem 1.5rem 1rem;
    background: linear-gradient(
      225deg,
      hsl(0 0% 50%) 0%,
      hsl(0 0% 96%) 70%
    );
    color: hsl(var(--background));
    font-family: 'Bangers', cursive;
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0.02em;
    text-align: center;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.9);
    white-space: nowrap;
  }

  .about-content > :global(h1:first-of-type + p) {
    grid-column: 1 / -1;
    margin-top: var(--about-intro-gap);
    text-align: left;
  }

  .about-content > :global(:not(.about-avatar):not(:is(h1, h2):first-of-type)) {
    grid-column: 1 / -1;
  }

  .about-content :global(.about-divider) {
    margin: 2rem 0;
    border: none;
    border-top: 1px solid hsl(var(--border));
    opacity: 0.5;
  }

  .about-content :global(.about-thanks) {
    display: block;
    text-align: center;
    font-size: 0.875rem;
  }

  .about-content :global(.about-play-aside) {
    position: relative;
    isolation: isolate;
    width: min(100vw, 1040px);
    box-sizing: border-box;
    margin: 4rem 0 2.25rem 50%;
    padding: 0;
    transform: translateX(-50%);
  }

  .about-content :global(.about-play-aside::before) {
    content: '';
    position: absolute;
    left: calc((100vw - min(100vw, 1040px)) / -2);
    right: calc((100vw - min(100vw, 1040px)) / -2);
    top: 5.2rem;
    bottom: -2rem;
    z-index: -1;
    background:
      linear-gradient(
        180deg,
        hsl(var(--background) / 0) 0%,
        hsl(var(--background) / 0) 64%,
        hsl(var(--background) / 0.72) 82%,
        hsl(var(--background)) 100%
      ),
      linear-gradient(
        135deg,
        transparent 8%,
        hsl(267 78% 56% / 0.075) 24%,
        hsl(267 78% 56% / 0.018) 31%,
        transparent 39%,
        hsl(28 92% 56% / 0.04) 68%,
        transparent 78%
      ),
      linear-gradient(
        135deg,
        transparent 20%,
        hsl(267 78% 56% / 0.032) 32%,
        transparent 41%,
        hsl(28 92% 56% / 0.052) 75%,
        transparent 86%
      ),
      radial-gradient(ellipse 28% 18% at 16% 18%, hsl(267 78% 56% / 0.085), transparent 72%),
      radial-gradient(ellipse 30% 20% at 84% 80%, hsl(28 92% 56% / 0.07), transparent 74%);
    filter: blur(8px);
    pointer-events: none;
  }

  .about-content :global(.about-play-heading) {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .about-content :global(.about-play-symbols) {
    --symbol-line-size: 2.5px;
    --symbol-size: 4.3rem;
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, var(--symbol-size));
    justify-content: center;
    align-items: center;
    gap: clamp(1.1rem, 5vw, 3rem);
    margin: 0 auto 3rem;
  }

  .about-content :global(.about-play-symbols::before) {
    content: '';
    position: absolute;
    left: calc((100vw - min(100vw, 1040px)) / -2);
    right: calc((100vw - min(100vw, 1040px)) / -2);
    top: calc(50% - var(--symbol-line-size) / 2);
    height: var(--symbol-line-size);
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      hsl(0 0% 100% / 0) 0%,
      hsl(0 0% 100% / 0.08) 8%,
      hsl(0 0% 100% / 0.48) 22%,
      hsl(0 0% 100% / 0.88) 38%,
      hsl(0 0% 100% / 0.88) 64%,
      hsl(0 0% 100% / 0.48) 78%,
      hsl(0 0% 100% / 0.08) 92%,
      hsl(0 0% 100% / 0) 100%
    );
  }

  .about-content :global(.about-play-symbol) {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--symbol-size);
    height: var(--symbol-size);
    border: var(--symbol-line-size) solid hsl(0 0% 100% / 0.88);
    border-radius: 999px;
    background: hsl(var(--background));
    color: hsl(0 0% 100% / 0.94);
  }

  .about-content :global(.about-play-symbol svg) {
    display: block;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .about-content :global(.about-play-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .about-content :global(.about-play-card) {
    position: relative;
    min-width: 0;
    padding: 1rem;
    border: none;
    border-radius: 0;
    background: rgb(0 0 0 / 0.7);
  }

  .about-content :global(.about-play-card::before) {
    content: '';
    position: absolute;
    inset: 0;
    padding: 1px;
    background: linear-gradient(
      180deg,
      hsl(0 0% 100% / 0.52) 0%,
      hsl(var(--border) / 0.34) 42%,
      hsl(var(--border) / 0) 100%
    );
    pointer-events: none;
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    mask-composite: exclude;
  }

  .about-content :global(.about-play-card::after) {
    content: '';
    display: block;
    clear: both;
  }

  .about-content :global(.about-play-logo) {
    float: left;
    width: calc(4.35rem + 4px);
    height: calc(4.35rem + 4px);
    margin: 0 0.9rem 0.35rem 0;
    border: none;
    border-radius: 0;
    object-fit: cover;
  }

  .about-content :global(.about-play-card h3) {
    margin: 0 0 0.65rem;
    color: hsl(var(--foreground));
    font-size: 1.05rem;
    line-height: 1.2;
  }

  .about-content :global(.about-play-card p) {
    margin: 0 0 0.8rem;
    font-size: 0.94rem;
    line-height: 1.62;
  }

  .about-content :global(.about-play-card p:last-of-type) {
    margin-bottom: 1rem;
  }

  .about-content :global(.about-play-links) {
    clear: both;
    display: grid;
    gap: 0.7rem;
    align-content: start;
    padding-top: 0.15rem;
  }

  .about-content :global(.about-channel-card) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 4rem;
    padding: 0.75rem;
    border: 1px solid hsl(var(--border) / 0.85);
    border-radius: 0;
    background: hsl(var(--background) / 0.78);
    color: hsl(var(--foreground));
    text-decoration: none;
    transition: border-color 160ms ease, transform 160ms ease, background 160ms ease;
  }

  .about-content :global(.about-channel-card:hover),
  .about-content :global(.about-channel-card:focus-visible) {
    border-color: hsl(var(--primary) / 0.85);
    transform: translateY(-1px);
  }

  .about-content :global(.about-channel-card-discord) {
    border-color: rgb(88 101 242 / 0.45);
    background:
      linear-gradient(135deg, rgb(88 101 242 / 0.24), rgb(88 101 242 / 0.07)),
      hsl(var(--background) / 0.78);
  }

  .about-content :global(.about-channel-card-discord:hover),
  .about-content :global(.about-channel-card-discord:focus-visible) {
    border-color: rgb(88 101 242 / 0.78);
    background:
      linear-gradient(135deg, rgb(88 101 242 / 0.32), rgb(88 101 242 / 0.1)),
      hsl(var(--card));
  }

  .about-content :global(.about-channel-card strong),
  .about-content :global(.about-channel-card small) {
    display: block;
  }

  .about-content :global(.about-channel-card strong) {
    font-size: 0.92rem;
    line-height: 1.2;
  }

  .about-content :global(.about-channel-card small) {
    margin-top: 0.2rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.78rem;
    line-height: 1.2;
  }

  .about-content :global(.about-channel-icon) {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 999px;
    background: hsl(0 0% 100% / 0.08);
    color: #ff0000;
  }

  .about-content :global(.about-channel-card-discord .about-channel-icon) {
    color: #5865f2;
  }

  .about-content :global(.about-channel-icon-youtube) {
    color: #ff0000;
  }

  .about-content :global(.about-channel-icon svg) {
    display: block;
    fill: currentColor;
  }

  .about-content :global(.about-youtube-feature) {
    display: block;
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    border: 1px solid rgb(255 0 0 / 0.42);
    border-radius: 0;
    background: hsl(var(--background));
    color: white;
    text-decoration: none;
  }

  .about-content :global(.about-youtube-cover) {
    width: 100%;
    height: 100%;
    max-width: none;
    margin: 0;
    border: none;
    border-radius: 0;
    object-fit: cover;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .about-content :global(.about-youtube-feature::after) {
    content: '';
    position: absolute;
    inset: auto 0 0;
    z-index: 1;
    height: 42%;
    background: linear-gradient(180deg, transparent, rgb(0 0 0 / 0.48));
    pointer-events: none;
  }

  .about-content :global(.about-youtube-glass-header) {
    position: absolute;
    inset: 0 0 auto;
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 3.65rem;
    padding: 0.7rem 0.85rem;
    border-bottom: 1px solid rgb(255 255 255 / 0.18);
    background:
      linear-gradient(135deg, rgb(255 0 0 / 0.44), rgb(92 0 0 / 0.2));
    box-shadow: none;
    color: hsl(0 0% 98% / 0.96);
  }

  @supports (backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px)) {
    .about-content :global(.about-youtube-glass-header) {
      background:
        linear-gradient(135deg, rgb(255 0 0 / 0.36), rgb(92 0 0 / 0.16));
      backdrop-filter: blur(14px) saturate(1.35);
      -webkit-backdrop-filter: blur(14px) saturate(1.35);
    }
  }

  .about-content :global(.about-youtube-glass-header .about-channel-icon) {
    width: 2.35rem;
    height: 2.35rem;
    background: rgb(255 255 255 / 0.12);
    color: hsl(0 0% 100% / 0.96);
  }

  .about-content :global(.about-youtube-glass-header .about-youtube-triangle) {
    fill: rgb(90 0 0 / 0.7);
  }

  .about-content :global(.about-youtube-glass-header strong),
  .about-content :global(.about-youtube-glass-header small) {
    display: block;
  }

  .about-content :global(.about-youtube-glass-header strong) {
    font-size: 0.92rem;
    line-height: 1.2;
  }

  .about-content :global(.about-youtube-glass-header small) {
    margin-top: 0.2rem;
    color: hsl(0 0% 100% / 0.78);
    font-size: 0.78rem;
    line-height: 1.2;
  }

  .about-content :global(.about-youtube-play) {
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transform: translate(-50%, -50%);
    filter: drop-shadow(0 2px 8px rgb(0 0 0 / 0.45));
  }

  .about-content :global(.about-youtube-play svg path:first-child) {
    fill: #ff0000;
  }

  .about-content :global(.about-youtube-triangle) {
    fill: white;
  }

  .about-content :global(.about-youtube-label) {
    position: absolute;
    left: 0.8rem;
    right: 0.8rem;
    bottom: 0.72rem;
    z-index: 1;
    display: block;
    line-height: 1.2;
  }

  .about-content :global(.about-youtube-label strong),
  .about-content :global(.about-youtube-label small) {
    display: block;
  }

  .about-content :global(.about-youtube-label strong) {
    font-size: 0.92rem;
  }

  .about-content :global(.about-youtube-label small) {
    margin-top: 0.18rem;
    color: hsl(0 0% 100% / 0.78);
    font-size: 0.78rem;
  }

  .about-content :global(.about-youtube-feature:hover .about-youtube-cover),
  .about-content :global(.about-youtube-feature:focus-visible .about-youtube-cover) {
    opacity: 0.86;
    transform: scale(1.035);
  }

  .about-content :global(.about-avatar) {
    --avatar-size: var(--about-avatar-size);
    --avatar-border: none;
    --avatar-shadow: 0 4px 12px rgba(0, 0, 0, 0.5);
    grid-column: 2;
    grid-row: 1;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .about-section {
      --about-padding-x: 1.5rem;
      --about-padding-y: 1.5rem;
      --about-title-size: 1.75rem;
      --about-avatar-size: clamp(3.6rem, 19.8vw, 6.75rem);
      --about-intro-gap: 1.5rem;
      padding: var(--about-padding-y) var(--about-padding-x) 1.5rem !important;
      margin-top: 1.5rem !important;
    }

    .about-content > :global(h1:first-of-type) {
      margin-bottom: 0;
      font-size: clamp(1.7rem, 7vw, 2.5rem);
      gap: 0.5rem;
    }

    .about-content :global(.about-title-bubble) {
      padding: 1rem 1.1rem 0.85rem;
    }

    .about-content > :global(h1:first-of-type)::before {
      left: -18px;
      border-right-width: 34px;
      border-top-width: 18px;
      border-bottom-width: 18px;
    }

    .about-content :global(.about-play-aside) {
      width: 100%;
      margin: 2.25rem 0 2rem;
      padding: 1rem;
      transform: none;
    }

    .about-content :global(.about-play-grid) {
      grid-template-columns: 1fr;
    }

  }

  @media (max-width: 480px) {
    .about-section {
      --about-padding-x: 1rem;
      --about-padding-y: 1.5rem;
      --about-avatar-size: clamp(3.15rem, 16.2vw, 4.725rem);
      padding: var(--about-padding-y) var(--about-padding-x) 1.5rem !important;
      margin-top: 1rem !important;
    }
  }
</style>
