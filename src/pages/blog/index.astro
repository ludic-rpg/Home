---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Get all blog posts, filter out drafts, sort by date
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// Filenames have a YY-MM-DD_ prefix for chronological sorting in Obsidian;
// strip it so URLs stay clean. Keep in sync with src/pages/blog/[...slug].astro.
const DATE_PREFIX = /^\d{2}-\d{2}-\d{2}_/;
const urlSlug = (post) => post.slug.replace(DATE_PREFIX, '');
---

<BaseLayout
  title="Blog | Ludic RPG"
  description="Blog posts about tabletop RPG projects, props, apps, and creative experiments for Alien RPG and C.O.P.S. RPG."
  canonical="https://ludicrpg.com/blog"
  headerTagline="Blog"
>
  <div class="container">
    <div class="space-y-16">
      <!-- Blog Posts -->
      <section class="wireframe-border">
    <div class="space-y-6">
      <h2>All Posts</h2>

      {posts.length === 0 ? (
        <p class="no-posts">No blog posts yet. Check back soon!</p>
      ) : (
        <div class="blog-grid">
          {posts.map((post) => {
            const { title, description, publishDate, coverImage, tags } = post.data;
            const formattedDate = new Date(publishDate).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            });

            // Determine glow class
            let glowClass = '';
            if (tags.includes('alien-rpg')) {
              glowClass = 'glow-green';
            } else if (tags.includes('cops-rpg')) {
              glowClass = 'glow-blue';
            }

            return (
              <article class={`blog-card ${glowClass}`}>
                <a href={`/blog/${urlSlug(post)}`} class="blog-card-link">
                  {coverImage && (
                    <div class="blog-card-image">
                      <img src={coverImage} alt={title} loading="lazy" />
                    </div>
                  )}
                  <div class="blog-card-content">
                    <h3 class="blog-card-title">{title}</h3>
                    <div class="blog-card-meta">
                      <time datetime={publishDate.toISOString()}>{formattedDate}</time>
                    </div>
                    {tags.length > 0 && (
                      <div class="blog-card-tags">
                        {tags.map((tag) => (
                          <a href={`/blog/tags/${tag}`} class="tag" onclick="event.stopPropagation();">#{tag}</a>
                        ))}
                      </div>
                    )}
                    <p class="blog-card-description">{description}</p>
                    <span class="blog-card-cta">Read more →</span>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>
    </div>
  </div>
</BaseLayout>
