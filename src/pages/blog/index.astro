---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Get all blog posts, filter out drafts, sort by date
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// Filenames have a YY-MM-DD_ prefix for chronological sorting in Obsidian;
// strip it so URLs stay clean. Keep in sync with src/pages/blog/[...slug].astro.
const DATE_PREFIX = /^\d{2}-\d{2}-\d{2}_/;
const urlSlug = (post: { slug: string }) => post.slug.replace(DATE_PREFIX, '');
const canonical = 'https://ludicrpg.com/blog/';
const collectionItems = posts.map((post) => {
  const slug = urlSlug(post);
  return {
    name: post.data.title,
    url: `https://ludicrpg.com/blog/${slug}/`,
    description: post.data.teaser || post.data.description,
    image: post.data.coverImage,
    datePublished: post.data.publishDate.toISOString(),
  };
});
---

<BaseLayout
  title="Blog | Ludic RPG"
  description="Blog posts about tabletop RPG projects, props, apps, and creative experiments for Alien RPG and C.O.P.S. RPG."
  canonical={canonical}
  breadcrumbs={[
    { name: 'Home', url: 'https://ludicrpg.com/' },
    { name: 'Blog', url: canonical },
  ]}
  collectionItems={collectionItems}
  headerTagline="Blog"
  navBehavior="auto-hide"
>
  <div class="container">
    <div class="space-y-16">
      <!-- Blog Posts -->
      {posts.length === 0 ? (
        <p class="no-posts">No blog posts yet. Check back soon!</p>
      ) : (
        <div class="blog-grid">
          {posts.map((post) => {
            const { title, description, teaser, publishDate, coverImage, videoUrl, tags } = post.data;
            const date = new Date(publishDate);
            const formattedDate = `${date.toLocaleDateString('en-US', { month: 'short' })} ${date.getDate()} · ${date.getFullYear()}`;

            // Determine glow class
            let glowClass = '';
            if (tags.includes('alien-rpg')) {
              glowClass = 'glow-green';
            } else if (tags.includes('cops-rpg')) {
              glowClass = 'glow-blue';
            }

            // Check if post has a video URL
            const hasVideo = !!videoUrl;

            return (
              <article class={`blog-card ${glowClass}`}>
                <div class="blog-card-date-badge">
                  <time datetime={publishDate.toISOString()}>{formattedDate}</time>
                </div>
                {coverImage && (
                  <a href={`/blog/${urlSlug(post)}`} class="blog-card-image-link">
                    <div class={`blog-card-image ${hasVideo ? 'has-video-thumbnail' : ''}`}>
                      <img src={coverImage} alt={title} loading="lazy" />
                    </div>
                  </a>
                )}
                <div class="blog-card-content">
                  <h3 class="blog-card-title">
                    <a href={`/blog/${urlSlug(post)}`}>{title}</a>
                  </h3>
                  {tags.length > 0 && (
                    <div class="blog-card-tags">
                      {tags.map((tag) => (
                        <a href={`/blog/tags/${tag}`} class="tag">#{tag}</a>
                      ))}
                    </div>
                  )}
                  <p class="blog-card-description">{teaser || description}</p>
                  <a href={`/blog/${urlSlug(post)}`} class="blog-card-cta">Read more →</a>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </div>
</BaseLayout>
