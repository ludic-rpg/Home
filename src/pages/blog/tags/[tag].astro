---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

// SEO metadata per tag. Add new tags here as the blog grows so each one
// gets a focused title + meta description (not just a generic fallback).
const TAG_META = {
  'ludic-field': {
    display: 'Ludic Field',
    description:
      'Ludic Field is my modern RPG map viewer for sci-fi and futuristic TTRPG campaigns. Browse releases, dev logs, and experiments behind the project.',
  },
  'alien-rpg': {
    display: 'Alien RPG',
    description:
      'Alien RPG posts: campaign prep, custom props, the motion tracker app, and lessons from running Heart of Darkness at the table.',
  },
  'cops-rpg': {
    display: 'C.O.P.S. RPG',
    description:
      'C.O.P.S. tabletop RPG, the modern dystopian police RPG. Notes, props, and tools for running it.',
  },
  'release-notes': {
    display: 'Release Notes',
    description:
      'Release notes for Ludic Field, the modern RPG map viewer for sci-fi and futuristic TTRPG campaigns.',
  },
  'dev-log': {
    display: 'Dev Log',
    description:
      'Engineering and design dev logs for Ludic Field, custom GM tools, and other TTRPG projects.',
  },
  'ttrpg-campaign': {
    display: 'TTRPG Campaign',
    description:
      'TTRPG campaign posts: running, prepping, and recapping tabletop RPG campaigns at the table.',
  },
  'behind-the-scenes': {
    display: 'Behind the Scenes',
    description:
      'Behind the scenes of my tabletop RPG sessions: post-mortems, design decisions, and what really happened at the table.',
  },
  'alien-motion-tracker': {
    display: 'Alien Motion Tracker',
    description:
      'The Alien motion tracker prop and smartphone app: iconic sound, radar pulse, and the table tension it creates.',
  },
  props: {
    display: 'Props',
    description:
      'Tabletop RPG props: physical and digital pieces that make sessions feel real.',
  },
  'ttrpg-map': {
    display: 'TTRPG Map',
    description:
      'TTRPG map posts: schematic, modern, and futuristic maps built for tabletop RPG sessions.',
  },
  'futuristic-map': {
    display: 'Futuristic Map',
    description:
      'Futuristic RPG and TTRPG map posts: sci-fi schematics, station blueprints, and Ludic Field experiments.',
  },
  'sci-fi-rpg-map': {
    display: 'Sci-Fi RPG Map',
    description:
      'Sci-fi RPG map posts: starships, stations, and dystopian interiors for tabletop campaigns.',
  },
  'modern-rpg-map': {
    display: 'Modern RPG Map',
    description:
      'Modern RPG map posts: urban, contemporary, and police-procedural settings for tabletop campaigns.',
  },
  'gm-tools': {
    display: 'GM Tools',
    description:
      'GM tools for tabletop RPG: motion tracker apps, lights, audio, map viewers, and immersive table setups.',
  },
};

export async function getStaticPaths() {
  const DATE_PREFIX = /^\d{2}-\d{2}-\d{2}_/;
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  const tagMap = new Map();
  for (const post of posts) {
    for (const tag of post.data.tags || []) {
      if (!tagMap.has(tag)) tagMap.set(tag, []);
      tagMap.get(tag).push({
        slug: post.slug.replace(DATE_PREFIX, ''),
        data: post.data,
      });
    }
  }
  return Array.from(tagMap.entries()).map(([tag, items]) => ({
    params: { tag },
    props: {
      tag,
      posts: items.sort(
        (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
      ),
    },
  }));
}

const { tag, posts } = Astro.props;
const meta = TAG_META[tag] || {
  display: tag.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()),
  description: `All posts tagged "${tag}" on Ludic RPG: tabletop RPG tools, modern and futuristic maps, and behind-the-scenes notes.`,
};
const title = `${meta.display} — Ludic RPG Blog`;
const canonical = `https://ludicrpg.com/blog/tags/${tag}`;
---

<BaseLayout
  title={title}
  description={meta.description}
  canonical={canonical}
  headerTagline={`${posts.length} post${posts.length === 1 ? '' : 's'} tagged #${tag}`}
  headerBreadcrumb={{ label: '← All posts', href: '/blog' }}
>
  <div class="container">
    <div class="space-y-16">
      <section class="wireframe-border">
    <div class="space-y-6">
      <p class="tag-page-intro">{meta.description}</p>

      <div class="blog-grid">
        {posts.map((post) => {
          const { title: postTitle, description, publishDate, coverImage, tags } = post.data;
          const formattedDate = new Date(publishDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          let glowClass = '';
          if (tags.includes('alien-rpg')) glowClass = 'glow-green';
          else if (tags.includes('cops-rpg')) glowClass = 'glow-blue';
          return (
            <article class={`blog-card ${glowClass}`}>
              <a href={`/blog/${post.slug}`} class="blog-card-link">
                {coverImage && (
                  <div class="blog-card-image">
                    <img src={coverImage} alt={postTitle} loading="lazy" />
                  </div>
                )}
                <div class="blog-card-content">
                  <h3 class="blog-card-title">{postTitle}</h3>
                  <div class="blog-card-meta">
                    <time datetime={new Date(publishDate).toISOString()}>{formattedDate}</time>
                  </div>
                  {tags.length > 0 && (
                    <div class="blog-card-tags">
                      {tags.map((t) => (
                        <a href={`/blog/tags/${t}`} class="tag" onclick="event.stopPropagation();">#{t}</a>
                      ))}
                    </div>
                  )}
                  <p class="blog-card-description">{description}</p>
                  <span class="blog-card-cta">Read more →</span>
                </div>
              </a>
            </article>
          );
        })}
      </div>
    </div>
  </section>
    </div>
  </div>
</BaseLayout>

<style>
  .tag-page-intro {
    font-size: 0.95rem;
    opacity: 0.85;
    max-width: 56ch;
    margin: 0 0 1.5rem;
  }
</style>
