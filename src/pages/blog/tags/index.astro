---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
const tagCounts = new Map();
for (const post of posts) {
  for (const tag of post.data.tags || []) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}
// Sort by count desc, then alpha
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));

const title = 'All Tags - Ludic RPG Blog';
const description =
  'Browse every Ludic RPG blog topic: modern and futuristic TTRPG maps, Alien RPG, Ludic Field releases, dev logs, GM tools, and behind-the-scenes notes.';
const canonical = 'https://ludicrpg.com/blog/tags/';
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  breadcrumbs={[
    { name: 'Home', url: 'https://ludicrpg.com/' },
    { name: 'Blog', url: 'https://ludicrpg.com/blog/' },
    { name: 'Tags', url: canonical },
  ]}
  headerTagline={`${tags.length} topics across ${posts.length} posts`}
  headerBreadcrumb={{ label: '← All posts', href: '/blog' }}
  navBehavior="auto-hide"
>
  <div class="container">
    <div class="space-y-16">
      <section class="wireframe-border">
    <div class="space-y-6">
      <p class="tag-cloud-intro">{description}</p>
      <ul class="tag-cloud">
        {tags.map(([tag, count]) => (
          <li>
            <a href={`/blog/tags/${tag}`} class="tag-cloud-link">
              #{tag}
              <span class="tag-cloud-count">{count}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
    </div>
  </div>
</BaseLayout>

<style>
  .tag-cloud-intro {
    font-size: 0.95rem;
    opacity: 0.85;
    max-width: 56ch;
    margin: 0 0 1.5rem;
  }
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .tag-cloud-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    padding: 0.45rem 0.8rem;
    font-size: 0.9rem;
    color: inherit;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }
  .tag-cloud-link:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.22);
  }
  .tag-cloud-count {
    font-size: 0.75rem;
    opacity: 0.6;
  }
</style>
