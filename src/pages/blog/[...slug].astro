---
import { getCollection } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import { blogSlug, blogUrl, resolveBlogAsset } from '../../lib/blog/posts';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sortedPosts = posts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
  return sortedPosts.map((post, index) => {
    const publicSlug = blogSlug(post);
    const nextPost = sortedPosts[index + 1] ?? sortedPosts[0];
    const nextPublicSlug = blogSlug(nextPost);
    return {
      params: { slug: publicSlug },
      props: {
        post,
        publicSlug,
        coverImage: resolveBlogAsset(post, post.data.coverImage),
        nextPost: nextPublicSlug === publicSlug ? null : {
          title: nextPost.data.title,
          teaser: nextPost.data.teaser ?? nextPost.data.description,
          href: blogUrl(nextPost),
        },
      },
    };
  });
}

const { post, publicSlug, coverImage, nextPost } = Astro.props;
const { Content } = await post.render();
---

<BlogPostLayout frontmatter={{ ...post.data, coverImage }} slug={publicSlug} nextPost={nextPost}>
  <Content />
</BlogPostLayout>
