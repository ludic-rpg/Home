---
import { getCollection } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';

// Filenames are prefixed with YY-MM-DD_ for chronological sorting in Obsidian.
// Strip that prefix when building URLs so /blog/<slug> stays clean.
// (Defined inside getStaticPaths because Astro evaluates it in an isolated
// scope at build time, so module-level consts aren't visible there.)
export async function getStaticPaths() {
  const DATE_PREFIX = /^\d{2}-\d{2}-\d{2}_/;
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sortedPosts = posts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
  return sortedPosts.map((post, index) => {
    const publicSlug = post.slug.replace(DATE_PREFIX, '');
    const nextPost = sortedPosts[index + 1] ?? sortedPosts[0];
    const nextPublicSlug = nextPost.slug.replace(DATE_PREFIX, '');
    return {
      params: { slug: publicSlug },
      props: {
        post,
        publicSlug,
        nextPost: nextPublicSlug === publicSlug ? null : {
          title: nextPost.data.title,
          teaser: nextPost.data.teaser ?? nextPost.data.description,
          href: `/blog/${nextPublicSlug}/`,
        },
      },
    };
  });
}

const { post, publicSlug, nextPost } = Astro.props;
const { Content } = await post.render();
---

<BlogPostLayout frontmatter={post.data} slug={publicSlug} nextPost={nextPost}>
  <Content />
</BlogPostLayout>
