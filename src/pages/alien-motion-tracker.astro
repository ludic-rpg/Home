<script>
  const themeCards = document.querySelectorAll<HTMLElement>('.theme-preview');
  const soundIdleLabel = 'In-app sound';
  const soundActiveLabel = 'Stop';

  let activeSound: {
    video: HTMLVideoElement;
    button: HTMLButtonElement;
    timeoutId: number;
  } | null = null;

  const resetSoundButton = (button: HTMLButtonElement) => {
    button.classList.remove('is-playing-sound');
    const label = button.querySelector<HTMLElement>('.sound-label');
    if (label) label.textContent = soundIdleLabel;
    button.setAttribute('aria-pressed', 'false');
    button.setAttribute('aria-label', button.dataset.idleAriaLabel ?? soundIdleLabel);
  };

  const playMutedLoop = (video: HTMLVideoElement) => {
    video.muted = true;
    video.volume = 0;
    video.loop = true;
    void video.play().catch(() => {
      // Muted autoplay can still be blocked by user/browser settings; a later sound click restarts it.
    });
  };

  const stopActiveSound = (restartLoopFromStart = false) => {
    if (activeSound === null) return;

    const { video, button, timeoutId } = activeSound;
    activeSound = null;
    window.clearTimeout(timeoutId);
    video.muted = true;
    video.volume = 0;
    video.loop = true;
    if (restartLoopFromStart) {
      video.currentTime = 0;
    }
    resetSoundButton(button);
    void video.play().catch(() => {
      // Keep the visible state muted; playback resumes on the next permitted interaction.
    });
  };

  themeCards.forEach((card) => {
    const video = card.querySelector<HTMLVideoElement>('video');
    const soundButton = card.querySelector<HTMLButtonElement>('.theme-sound-toggle');
    if (!video || !soundButton) return;

    soundButton.dataset.idleAriaLabel = soundButton.getAttribute('aria-label') ?? soundIdleLabel;
    video.muted = true;
    video.volume = 0;
    video.loop = true;
    playMutedLoop(video);

    soundButton.addEventListener('click', async () => {
      if (activeSound?.button === soundButton) {
        stopActiveSound(false);
        return;
      }

      stopActiveSound(false);
      const durationSec = Number.isFinite(video.duration) && video.duration > 0
          ? video.duration
          : 10;
      const timeoutId = window.setTimeout(() => {
        if (activeSound?.video === video) {
          stopActiveSound(true);
        }
      }, Math.max(500, durationSec * 1000 + 150));

      activeSound = { video, button: soundButton, timeoutId };
      video.loop = false;
      video.volume = 1;
      video.currentTime = 0;

      if (video.paused) {
        try {
          await video.play();
        } catch {
          stopActiveSound(false);
          return;
        }
      }

      video.muted = false;
      if (video.paused) {
        try {
          await video.play();
        } catch {
          stopActiveSound(false);
          return;
        }
      }

      soundButton.classList.add('is-playing-sound');
      const label = soundButton.querySelector<HTMLElement>('.sound-label');
      if (label) label.textContent = soundActiveLabel;
      soundButton.setAttribute('aria-pressed', 'true');
      soundButton.setAttribute('aria-label', 'Stop in-app sound');
    });
  });

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) return;
    themeCards.forEach((card) => {
      const video = card.querySelector<HTMLVideoElement>('video');
      if (video && activeSound?.video !== video) playMutedLoop(video);
    });
  });
</script>
