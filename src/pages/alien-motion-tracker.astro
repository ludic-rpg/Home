---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AvatarBubble from '../components/AvatarBubble.astro';
import BlogCard from '../components/blog/BlogCard.astro';
import SocialIcon from '../components/SocialIcon.astro';
import YouTubeFacade from '../components/youtube/Facade.astro';
import { blogSlug, blogUrl, resolveBlogAsset } from '../lib/blog/posts';
import { SITE_URL } from '../lib/seo/constants';

const canonical = `${SITE_URL}/alien-motion-tracker/`;
const privacyUrl = `${SITE_URL}/alien-motion-tracker/privacy/`;
const codeOfConductUrl = `${SITE_URL}/code-of-conduct/`;
const privacyPath = '/alien-motion-tracker/privacy/';
const codeOfConductPath = '/code-of-conduct/';
const discordUrl = 'https://discord.gg/qmHgDDyc7d';
const demoUrl = 'https://www.reddit.com/r/alienrpg/comments/1o6pf22/motion_tracker_app_for_inpersontabletop/';
const remoteModeTutorialUrl = 'https://www.youtube.com/watch?v=WihNWhApbAk';
const remoteModeTutorialId = 'WihNWhApbAk';
const heroImage = '/assets/img/projects/alien-rpg/alien-motion-tracker-app-hero-tabletop-photo.webp';
const remoteModeTutorialPoster = '/assets/img/projects/alien-rpg/alien-motion-tracker-app-ttrpg-remote-control-manual.webp';
const ambientAvatarVideos = [
  '/assets/video/avatar/avatar-dog-angry.mp4',
  '/assets/video/avatar/avatar-dog-curious-ear.mp4',
  '/assets/video/avatar/avatar-wind-hair.mp4',
  '/assets/video/avatar/avatar-dog-look-right-a.mp4',
  '/assets/video/avatar/avatar-dog-look-right-b.mp4',
];
const terminalProgressSegments = Array.from({ length: 25 }, (_, index) => ({
  className:
    index < 23
      ? 'terminal-progress-fill'
      : index === 23
        ? 'terminal-progress-current'
        : 'terminal-progress-empty',
}));
const pageTitle = 'Alien Motion Tracker App for Alien RPG Table Sessions | Ludic RPG';
const pageDescription =
  'A remote-controlled Alien RPG motion tracker prop app for in-person sessions, built to recreate iconic tracker scenes at the table with local Wi-Fi play and a physical 360-degree phone sweep.';
const softwareId = `${canonical}#software`;
const faqId = `${canonical}#faq`;
const howToId = `${canonical}#how-to`;
const absoluteUrl = (path: string) => path.startsWith('http') ? path : `${SITE_URL}${path.startsWith('/') ? '' : '/'}${path}`;
const themeScreenshots = [
  {
    name: 'Nostromo Device',
    label: 'Alien 1979',
    description: 'Rudimentary grid-based motion device, with scene-accurate pulses and contact sounds.',
    src: '/assets/img/projects/alien-rpg/alien-motion-tracker-nostromo-device-alien-1979.webp',
    videoSrc: '/assets/img/projects/alien-rpg/alien-motion-tracker-nostromo-device-alien-1979-video-preview.mp4',
    alt: 'Alien motion tracker from Alien 1979, Nostromo Device theme with blue grid and contact echoes',
    title: 'Alien motion tracker from Alien 1979',
    imageClass: 'theme-image-nostromo',
    previewClass: 'theme-preview-nostromo',
  },
  {
    name: 'M313 Motion Tracker',
    label: 'Aliens 1986',
    description: 'Issued to the Colonial Marines, with an authentic pulse-wave beat and echo sound effect.',
    src: '/assets/img/projects/alien-rpg/alien-motion-tracker-m313-motion-tracker-aliens-1986.webp',
    videoSrc: '/assets/img/projects/alien-rpg/alien-motion-tracker-m313-motion-tracker-aliens-1986-video-preview.mp4',
    alt: 'Alien motion tracker from Aliens 1986, M313 Motion Tracker with blue radar arc and contact blips',
    title: 'Alien motion tracker from Aliens 1986',
    imageClass: 'theme-image-m313',
    previewClass: 'theme-preview-m313',
  },
  {
    name: 'Arious Modified',
    label: 'Alien: Isolation 2014',
    description: "Amanda Ripley's model, with accurate lighting and signature distorted pitch.",
    src: '/assets/img/projects/alien-rpg/alien-motion-tracker-arious-modified-alien-isolation-2014.webp',
    videoSrc: '/assets/img/projects/alien-rpg/alien-motion-tracker-arious-modified-alien-isolation-2014-video-preview.mp4',
    alt: 'Alien motion tracker from Alien Isolation 2014, Arious Modified theme with green sweep and contact blip',
    title: 'Alien motion tracker from Alien: Isolation 2014',
    imageClass: 'theme-image-isolation',
    previewClass: 'theme-preview-arious',
  },
];

const motionTrackerPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft && post.data.tags?.includes('alien-motion-tracker'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .map((post) => ({
    slug: blogSlug(post),
    url: blogUrl(post),
    coverImage: resolveBlogAsset(post, post.data.coverImage),
    data: post.data,
  }));

const collectionItems = motionTrackerPosts.map((post) => ({
  name: post.data.title,
  url: `${SITE_URL}${post.url}`,
  description: post.data.teaser || post.data.description,
  image: post.coverImage,
  datePublished: post.data.publishDate.toISOString(),
}));

const faqSchemaItems = [
  {
    question: 'What is the Alien Motion Tracker app?',
    answer:
      'It is an unofficial GM-controlled motion tracker prop app for in-person Alien RPG sessions. The GM places and moves hidden echoes from one phone; a player uses another phone as the tracker.',
  },
  {
    question: 'What do we need at the table?',
    answer:
      'For GM mode, you need at least two phones: one for the GM controls and one for the player tracker. The app is lightweight and free for players, so one player can install it during the session. You need to accept local network permission on first launch. The app does not use the internet, but GM remote control requires Wi-Fi, preferably a private or home network, with the GM phone and player phones connected to the same Wi-Fi. Solo mode works on one phone. I do not collect data, and I do not plan to. Not even for debug reports.',
  },
  {
    question: 'As a player, is the app free to join a GM session?',
    answer:
      'Yes. Players can join a GM session for free. Not every player needs to install it: the tracker is designed around one active operator who sweeps, reads the signal, and calls out what they see while everyone reacts. Players only need to purchase if they want all tracker themes in solo mode, or if they want to support the project.',
  },
  {
    question: 'When should I use it during a session?',
    answer:
      'Use it when movement, proximity, or uncertainty matters: corridors, vents, darkness, sealed rooms, false positives, incoming contacts, or any scene where the danger should be felt before it is explained. You can use it with theater of the mind, a rough sketch, a table map, or no map at all.',
  },
  {
    question: 'What does the GM control, and does it add rules?',
    answer:
      'The GM can place echoes, draw paths to move them, delete them, recenter when the player changes position, and pre-select or switch the tracker theme on the player device. It is a playable prop, not a rules module. On the GM side, positioning uses indicators for Adjacent, Short, Medium, and Long range bands. Extreme range is not included because motion trackers do not detect that far in the lore or the rules.',
  },
  {
    question: 'Can several trackers or several tables run at the same time?',
    answer:
      'Several player trackers can be active if their characters are grouped together. The app uses one shared party position, so every tracker reads the same contacts. For several GMs in the same room, this is a known limitation: the app is designed for single-table play. In conventions or clubs, each table needs a specific, isolated Wi-Fi network to avoid player connection issues.',
  },
  {
    question: 'Can I use it on a laptop, tablet, emulator, or VTT?',
    answer:
      'No laptop or emulator support is planned for the tracker because it uses phone motion sensors like the gyroscope and accelerometer. It may work on tablets, as they usually have the required sensors; the GM interface should work well, but the tracker interface may feel too large. You could use it alongside Roll20 or Foundry, but the app is designed for in-person sessions where players physically sweep and rotate their phones.',
  },
  {
    question: 'If I change phone, do I need to buy GM mode again?',
    answer:
      'No, not if you stay on the same platform. If you change iPhone, restore the purchase with the same Apple Account. If you change Android phone, use the same Google Play account. Apple and Android are separate stores, so a purchase on one will not automatically unlock GM mode on the other.',
  },
  {
    question: 'Is this official Alien RPG material?',
    answer:
      'No. It is an unofficial fan-made table tool, not affiliated with or endorsed by Free League or the Alien franchise owners.',
  },
];

const howToSteps = [
  'Download the app on two phones.',
  'Connect both phones to the same Wi-Fi network.',
  'Set one phone as the Admin phone and the other as the player tracker.',
  'Choose the tracker theme shown on the player phone to match the character inventory.',
  'Run the quick calibration phase with the Admin and player phones.',
  'Place and move targets from the Admin phone so they appear on the player tracker.',
  'Prepare target movements and play them later on the player tracker.',
  'Recenter the scene when the player character moves so targets keep their relative positions.',
];

const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  '@id': softwareId,
  name: 'Alien Motion Tracker',
  alternateName: ['Alien RPG Motion Tracker', 'Ludic RPG Alien Motion Tracker'],
  url: canonical,
  image: absoluteUrl(heroImage),
  screenshot: themeScreenshots.map((theme) => ({
    '@type': 'ImageObject',
    url: absoluteUrl(theme.src),
    name: theme.title,
    caption: `${theme.name} - ${theme.label}`,
    description: theme.description,
  })),
  applicationCategory: 'GameApplication',
  applicationSubCategory: 'Tabletop role-playing game aid',
  operatingSystem: 'iOS, Android',
  description: pageDescription,
  creator: { '@id': `${SITE_URL}/#ludovic-fleury` },
  publisher: { '@id': `${SITE_URL}/#organization` },
  audience: {
    '@type': 'Audience',
    audienceType: 'Alien RPG game masters and tabletop RPG players',
  },
  featureList: [
    'GM-controlled echoes for Alien RPG table sessions',
    'Free player tracker for GM sessions',
    'GM remote control with no subscription, no cosmetic microtransactions, and no ads',
    'Remote echo control: tap to place, draw movement paths, prepare multiple movements, play them together, and recenter',
    'Physical 360-degree phone sweep using mobile motion sensors',
    'Local Wi-Fi play without internet accounts or online rooms',
    'Nostromo Device, M313 Motion Tracker, and Arious Modified tracker recreations with distinct iconic identities',
    'Tracker-specific interface behavior, visual effects, motion timing, pitch, sync, sounds, and screen behavior',
    'Range indicators for Adjacent, Short, Medium, and Long',
  ],
  softwareRequirements:
    'GM remote control requires a GM phone and one or more player phones connected to the same local Wi-Fi network. Solo mode works on one phone.',
  sameAs: [demoUrl],
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': faqId,
  mainEntity: faqSchemaItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const howToJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  '@id': howToId,
  name: 'How to use remote control mode for an Alien Motion Tracker table session',
  description:
    'A remote control table setup for using one Admin phone to control targets on a player tracker phone during an in-person Alien RPG session.',
  image: absoluteUrl(heroImage),
  tool: [
    { '@type': 'HowToTool', name: 'GM phone' },
    { '@type': 'HowToTool', name: 'Player phone' },
    { '@type': 'HowToTool', name: 'Local Wi-Fi network' },
  ],
  step: howToSteps.map((text, index) => ({
    '@type': 'HowToStep',
    position: index + 1,
    text,
  })),
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  ogImage={heroImage}
  ogImageAlt="Alien Motion Tracker app interface for in-person Alien RPG table sessions"
  breadcrumbs={[
    { name: 'Home', url: `${SITE_URL}/` },
    { name: 'Alien Motion Tracker', url: canonical },
  ]}
  collectionItems={collectionItems}
  pageType="WebPage"
  mainEntityId={softwareId}
  significantLinks={[
    privacyUrl,
    `${SITE_URL}/blog/tags/alien-motion-tracker/`,
    `${SITE_URL}/blog/building-the-alien-rpg-motion-tracker-immersion-without-friction/`,
    demoUrl,
    remoteModeTutorialUrl,
    discordUrl,
  ]}
  mentions={[
    { '@id': softwareId },
    { '@id': faqId },
    { '@id': howToId },
  ]}
  jsonLdItems={[softwareJsonLd, faqJsonLd, howToJsonLd]}
  navBehavior="auto-hide"
  bodyClass="alien-motion-tracker-page"
>
  <div class="tracker-page">
    <section class="tracker-hero" aria-labelledby="tracker-title">
      <img class="tracker-hero-image" src={heroImage} alt="" aria-hidden="true" fetchpriority="high" />
      <div class="tracker-hero-vignette" aria-hidden="true"></div>
      <div class="tracker-hero-crt" aria-hidden="true"></div>
      <div class="tracker-hero-content">
        <p class="eyebrow hero-eyebrow">
          <span class="hero-eyebrow-desktop">Built for tabletop play. Made for Alien fans.</span>
          <span class="hero-eyebrow-mobile">Built for TTPRG. Made for Alien fans.</span>
        </p>
        <h1 id="tracker-title">Alien Motion Tracker</h1>
        <p class="hero-rhythm">The Admin taps. The player tracks.</p>
      </div>
      <div class="hero-cta-band">
        <div class="hero-actions" aria-label="Alien Motion Tracker actions">
          <a class="action action-primary" href={discordUrl} target="_blank" rel="noopener noreferrer" data-fathom-event="Click Motion Tracker Beta | Landing Hero">
            <span class="terminal-status">&gt; JOIN THE CLOSED BETA IN PROGRESS</span>
            <span class="terminal-progress" aria-hidden="true">
              {terminalProgressSegments.map((segment) => (
                <span class={segment.className}></span>
              ))}
            </span>
          </a>
        </div>
        <div class="store-badges" aria-label="App store availability">
          <div class="store-badge store-badge-disabled" aria-label="Coming soon on the App Store">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.6 12.4c0-2.8 2.3-4.1 2.4-4.2-1.3-1.9-3.3-2.2-4-2.2-1.7-.2-3.3 1-4.2 1-.9 0-2.2-1-3.6-1-1.8 0-3.5 1.1-4.5 2.7-1.9 3.4-.5 8.4 1.4 11.1.9 1.3 2 2.8 3.5 2.7 1.4-.1 1.9-.9 3.6-.9 1.7 0 2.2.9 3.7.9 1.5 0 2.5-1.3 3.4-2.7 1.1-1.5 1.5-3 1.5-3.1-.1 0-3.2-1.2-3.2-4.3ZM14.9 4.2c.8-.9 1.3-2.2 1.1-3.5-1.1 0-2.4.7-3.2 1.6-.7.8-1.3 2.1-1.1 3.3 1.2.1 2.4-.6 3.2-1.4Z" />
            </svg>
            <span>
              <small>Coming soon on the</small>
              <strong>App Store</strong>
            </span>
          </div>
          <div class="store-badge store-badge-disabled" aria-label="Coming soon on Google Play">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path class="play-blue" d="M4.5 2.5 14 12 4.5 21.5c-.3-.3-.5-.8-.5-1.3V3.8c0-.5.2-1 .5-1.3Z" />
              <path class="play-green" d="M14 12 16.9 9.1 6.2 3c-.7-.4-1.3-.5-1.7-.5L14 12Z" />
              <path class="play-yellow" d="M14 12 4.5 21.5c.4 0 1-.1 1.7-.5l10.7-6.1L14 12Z" />
              <path class="play-red" d="M16.9 9.1 20.1 11c1.2.7 1.2 1.3 0 2l-3.2 1.9L14 12l2.9-2.9Z" />
            </svg>
            <span>
              <small>Coming soon on</small>
              <strong>Google Play</strong>
            </span>
          </div>
        </div>
      </div>
    </section>

    <section class="quick-read" aria-label="Motion tracker summary">
      <div class="quick-read-inner">
        <div>
          <span class="metric">SOLO</span>
          <strong>mode</strong>
          <p>One phone: tap or drag directly on your screen to see the target move.</p>
        </div>
        <div>
          <span class="metric">REMOTE</span>
          <strong>mode</strong>
          <p>Two phones: one Admin phone moves targets; the player's phone tracks them.</p>
        </div>
        <div>
          <span class="metric">360 SWEEP</span>
          <strong>physical play</strong>
          <p>The player turns their phone, hears the pulse, finds the blip, and calls it out.</p>
        </div>
      </div>
    </section>

    <div class="container tracker-container">
      <div class="tracker-stack">
        <section class="section-band themes-section" aria-labelledby="themes-title">
          <div class="themes-copy">
            <p class="eyebrow">Iconic Identity</p>
            <h2 id="themes-title">Three authentic motion trackers.</h2>
            <p>
              Obsessive attention went into the tiny details: interface behavior, visual effects, motion timing, pitch, and sound sync. Each motion tracker had to feel exactly like the one we remembered and loved.
            </p>
          </div>
          <div class="theme-showcase">
            <div class="theme-screens" aria-label="Available tracker theme screenshots">
              {themeScreenshots.map((theme) => (
                <figure class={`theme-preview ${theme.previewClass}`}>
                  <div class="theme-media">
                    <video
                      class={theme.imageClass}
                      src={theme.videoSrc}
                      poster={theme.src}
                      title={theme.title}
                      aria-label={theme.alt}
                      muted
                      autoplay
                      loop
                      playsinline
                      preload="auto"
                    ></video>
                  </div>
                  <div class="theme-controls" aria-label={`${theme.name} preview controls`}>
                    <button class="theme-sound-toggle" type="button" aria-label={`Listen to ${theme.name} in-app sound`} aria-pressed="false">
                      <span class="sound-button-content">
                        <span class="sound-icons" aria-hidden="true">
                          <svg class="sound-icon sound-icon-speaker" viewBox="0 0 24 24">
                            <path d="M4 9.4h3.8L13 5v14l-5.2-4.4H4V9.4Z" />
                            <path d="M16.2 8.1c1 .9 1.6 2.3 1.6 3.9s-.6 3-1.6 3.9" />
                          </svg>
                          <span class="sound-wave sound-wave-1"></span>
                          <span class="sound-wave sound-wave-2"></span>
                          <span class="sound-wave sound-wave-3"></span>
                        </span>
                        <span class="sound-label">In-app sound</span>
                      </span>
                    </button>
                  </div>
                  <figcaption>
                    <div>
                      <strong>{theme.name}</strong>
                      <span>{theme.label}</span>
                      <p>{theme.description}</p>
                    </div>
                  </figcaption>
                </figure>
              ))}
            </div>
          </div>
        </section>

        <section class="section-band demo-section" aria-labelledby="demo-title">
          <div class="demo-heading">
            <p class="eyebrow">Remote Control For In-Person TTRPG Sessions</p>
            <h2 id="demo-title">How it works.</h2>
            <p class="demo-lead">
              Alien Motion Tracker Remote Mode is made for in-person TTRPG sessions: use one Admin phone to control targets on a player tracker phone.
            </p>
          </div>
          <div class="demo-video">
            <YouTubeFacade
              id={remoteModeTutorialId}
              title="Alien Motion Tracker remote mode tutorial"
              poster={remoteModeTutorialPoster}
              minimal={true}
            />
          </div>
          <div class="demo-constraints" aria-label="Remote mode requirements and limits">
            <article class="demo-constraint demo-constraint-network">
              <h3>Same Wi-Fi</h3>
              <p>Two phones should be on the same local Wi-Fi. No internet is required.</p>
            </article>
            <article class="demo-constraint demo-constraint-tracker-limit">
              <h3>1 tracker max per table</h3>
              <p>Best with one tracker. More can connect, but it is not recommended.</p>
            </article>
            <article class="demo-constraint demo-constraint-limit">
              <h3>1 GM max per Wi-Fi</h3>
              <p>The app cannot run two tables under the same Wi-Fi.</p>
            </article>
          </div>
        </section>

        <figure class="tracker-quote" aria-label="Alien tracker quote">
          <blockquote>
            <p>
              <span class="quote-mark quote-mark-left" aria-hidden="true">&laquo;</span>
              <span class="quote-text">Movements! I can't lock in... Multiple Signals</span>
              <span class="quote-mark quote-mark-right" aria-hidden="true">&raquo;</span>
            </p>
          </blockquote>
        </figure>

        <section class="play-value-section" aria-labelledby="play-value-title">
          <div class="play-value-grid">
            <article class="play-value-card play-value-card-suspense">
              <p class="eyebrow">Playable Suspense</p>
              <h2 id="play-value-title">Make Invisible Movement Playable</h2>
              <p>
                A hidden contact stops being only a sentence. It gamifies the suspense for your players. They can hear, sweep for, evaluate, and coordinate with the table.
              </p>
            </article>
            <article class="play-value-card play-value-card-gm">
              <p class="eyebrow">Built For GMs</p>
              <h2>Built For GMs, Zero Prep</h2>
              <p>
                The prop is made to support your scene without breaking your narration flow and game pacing. No technical setup, no heavy control panel, no new rules to explain.
              </p>
            </article>
          </div>
        </section>

        <section class="section-band beta-section" aria-labelledby="beta-title">
          <div>
            <p class="eyebrow">Respect Your Table</p>
            <h2 id="beta-title">No ads.<br />No tracking.</h2>
          </div>
          <div class="beta-copy">
            <p>
              Immersion guaranteed for your table: no ads, no pop-up, no account required. I do not access, collect, receive, or share any of your data. Everything stays on your phone. Remote mode uses local Wi-Fi so the phones at your table can talk to each other.
            </p>
            <div class="beta-actions">
              <a href={privacyPath} data-fathom-event="Click Motion Tracker Privacy | Landing Body">
                Read the privacy policy
              </a>
              <a href={codeOfConductPath} data-fathom-event="Click Code Of Conduct | Motion Tracker Landing">
                Read my code of conduct
              </a>
            </div>
          </div>
        </section>

        {motionTrackerPosts.length > 0 && (
          <section class="devlog-section" aria-labelledby="devlog-title">
            <div class="devlog-header">
              <div>
                <p class="eyebrow">Devlog</p>
                <h2 id="devlog-title">The Journey Behind The Tracker</h2>
              </div>
            </div>
            <ul class="devlog-grid" aria-label="Alien Motion Tracker devlog posts">
              {motionTrackerPosts.map((post) => (
                <BlogCard
                  title={post.data.title}
                  description={post.data.description}
                  teaser={post.data.teaser}
                  publishDate={post.data.publishDate}
                  url={post.url}
                  coverImage={post.coverImage}
                  videoUrl={post.data.videoUrl}
                  tags={post.data.tags}
                  dateDisplay="meta"
                />
              ))}
            </ul>
          </section>
        )}

        <section class="section-band faq-section" aria-labelledby="faq-title">
          <div class="faq-header">
            <p class="eyebrow">FAQ</p>
            <h2 id="faq-title">Questions before you bring it to the table.</h2>
          </div>
          <div class="faq-list">
            <details open>
              <summary>What is the Alien Motion Tracker app?</summary>
              <p>It is an unofficial GM-controlled motion tracker prop app for in-person Alien RPG sessions. The GM places and moves hidden echoes from one phone; a player uses another phone as the tracker.</p>
            </details>
            <details>
              <summary>What do we need at the table?</summary>
              <p>For GM mode, you need at least two phones: one for the GM controls and one for the player tracker. Since the app is lightweight and free for players, one player can install it even during the session. Solo mode works on one phone.</p>
              <p>You need to accept the local network permission on first launch. It allows the GM app and player apps to communicate.</p>
              <p>The app does not use the internet, but GM remote control requires Wi‑Fi, preferably a private or home network, with the GM phone and player phones connected to the same Wi‑Fi.</p>
              <p>I never use the internet to send any data. I do not collect data, and I do not plan to. Not even for debug reports.</p>
            </details>
            <details>
              <summary>As a player, is the app free to join a GM session?</summary>
              <p>Yes. Players can join a GM session for free. Not every player needs to install it: the tracker is designed around one active operator who sweeps, reads the signal, and calls out what they see while everyone reacts. Players only need to purchase if they want all tracker themes in solo mode, or if they want to support the project.</p>
            </details>
            <details>
              <summary>When should I use it during a session?</summary>
              <p>Use it when movement, proximity, or uncertainty matters: corridors, vents, darkness, sealed rooms, false positives, incoming contacts, or any scene where the danger should be felt before it is explained. You can use it with theater of the mind, a rough sketch, a table map, or no map at all.</p>
            </details>
            <details>
              <summary>What does the GM control, and does it add rules?</summary>
              <p>The GM can place echoes, draw paths to move them, delete them, recenter when the player changes position, and pre-select or switch the tracker theme on the player device. It is a playable prop, not a rules module. On the GM side, positioning uses indicators for the four official range bands: Adjacent, Short, Medium, and Long. Extreme range is not included because motion trackers do not detect that far in the lore or the rules.</p>
            </details>
            <details>
              <summary>Can several trackers or several tables run at the same time?</summary>
              <p><strong>Several player trackers:</strong> yes, if their characters are grouped together. The app uses one shared party position, so every tracker reads the same contacts.</p>
              <p><strong>Several GMs in the same room:</strong> this is a known limitation. The app is designed for single-table play. In conventions or clubs, each table needs a specific, isolated Wi‑Fi network to avoid player connection issues.</p>
            </details>
            <details>
              <summary>Can I use it on a laptop, tablet, emulator, or VTT?</summary>
              <p>No laptop or emulator support is planned for the tracker because it uses phone motion sensors like the gyroscope and accelerometer. It may work on tablets, as they usually have the required sensors; the GM interface should work well, but the tracker interface may feel too large. You could use it alongside Roll20 or Foundry, but the app is designed for in-person sessions where players physically sweep and rotate their phones.</p>
            </details>
            <details>
              <summary>If I change phone, do I need to buy GM mode again?</summary>
              <p>No, not if you stay on the same platform. If you change iPhone, restore the purchase with the same Apple Account. If you change Android phone, use the same Google Play account. Apple and Android are separate stores, so a purchase on one will not automatically unlock GM mode on the other.</p>
            </details>
            <details>
              <summary>Is this official Alien RPG material?</summary>
              <p>No. It is an unofficial fan-made table tool, not affiliated with or endorsed by Free League or the Alien franchise owners.</p>
            </details>
          </div>
          <div class="faq-discord">
            <div>
              <span class="faq-discord-kicker">Open channel</span>
              <h3>Not sure how it fits your table?</h3>
              <p>
                Ask me about your setup, your scene, the phones you have, or the weird convention Wi‑Fi situation before you run it.
              </p>
            </div>
            <a class="action action-primary" href={discordUrl} target="_blank" rel="noopener noreferrer" data-fathom-event="Click Motion Tracker Discord | FAQ">
              <SocialIcon icon="discord" tone="white" />
              Ask on Discord
            </a>
          </div>
        </section>

        <p class="disclaimer bottom-disclaimer">
          Unofficial fan-made table tool. Not affiliated with or endorsed by Free League or the Alien franchise owners.
        </p>

        <AvatarBubble class="photo-credit-bubble" ariaLabel="Photo credit" videoSrcs={ambientAvatarVideos}>
          Big up to <a href="https://kaonashi.dev/" target="_blank" rel="noopener noreferrer">Kaonashi</a> for the photos
        </AvatarBubble>
      </div>
    </div>
  </div>
</BaseLayout>

