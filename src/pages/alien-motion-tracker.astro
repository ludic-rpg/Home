  .sound-wave {
    position: absolute;
    top: 50%;
    left: 1.08rem;
    border: 1.6px solid currentColor;
    border-left: 0;
    border-radius: 0 999px 999px 0;
    opacity: 0;
    transform: translateY(-50%) scaleX(0.72);
